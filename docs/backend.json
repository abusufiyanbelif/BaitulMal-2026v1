{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Organizational member profile with granular permissions and linked donor identity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "User", "Donor", "Beneficiary"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "permissions": { "type": "object" },
        "linkedDonorId": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status"]
    },
    "PendingVerification": {
      "title": "PendingVerification",
      "description": "A staged record update requiring multi-party institutional approval.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "module": { "type": "string", "enum": ["donations", "beneficiaries", "campaigns", "leads", "donors", "users"] },
        "status": { "type": "string", "enum": ["Pending", "Partially Approved", "Approved", "Rejected"] },
        "assignedVerifierIds": { "type": "array", "items": { "type": "string" } },
        "newValue": { "type": "object" },
        "requestedBy": { "type": "object" }
      },
      "required": ["id", "module", "status", "assignedVerifierIds", "newValue"]
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Secure member registry."
    },
    "/pending_verifications/{id}": {
      "schema": "#/backend/entities/PendingVerification",
      "description": "Institutional audit trail for record modifications."
    },
    "/settings/{docId}": {
      "schema": "object",
      "description": "Global application branding and financial settings."
    }
  }
}
