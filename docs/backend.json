
{
  "entities": {
    "Donor": {
      "title": "Donor Profile",
      "description": "An individual or entity providing financial support to the organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique Firestore document ID." },
        "name": { "type": "string", "description": "Full name of the donor." },
        "phone": { "type": "string", "description": "Primary contact number." },
        "email": { "type": "string", "format": "email", "description": "Verified email address." },
        "address": { "type": "string", "description": "Residential or business address." },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "notes": { "type": "string", "description": "Institutional observations and context." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Donation": {
      "title": "Donation Record",
      "description": "A verified financial contribution linked to a cause.",
      "type": "object",
      "properties": {
        "donorId": { "type": "string", "description": "Reference to the Donor Profile ID." },
        "amount": { "type": "number" },
        "donationDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Canceled"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/donors/{donorId}": {
      "schema": { "$ref": "#/backend/entities/Donor" },
      "description": "Master registry of institutional contributors."
    },
    "/donations/{donationId}": {
      "schema": { "$ref": "#/backend/entities/Donation" },
      "description": "Verified financial transaction logs."
    }
  }
}
