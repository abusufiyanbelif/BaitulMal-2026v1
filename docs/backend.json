{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Organizational staff member or donor profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User", "Donor", "Beneficiary"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "permissions": { "type": "object" },
        "linkedDonorId": { "type": "string" },
        "linkedBeneficiaryId": { "type": "string" }
      }
    },
    "PendingVerification": {
      "title": "Pending Verification",
      "description": "Staged data update awaiting peer review.",
      "type": "object",
      "properties": {
        "targetId": { "type": "string" },
        "targetCollection": { "type": "string" },
        "module": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Partially Approved", "Approved", "Rejected"] },
        "assignedVerifierIds": { "type": "array", "items": { "type": "string" } },
        "newValue": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Master user and staff directory."
    },
    "/pending_verifications/{id}": {
      "schema": "#/backend/entities/PendingVerification",
      "description": "Registry of staged modifications awaiting approval."
    },
    "/donations/{id}": {
      "schema": "Donation",
      "description": "Financial contribution records."
    }
  }
}
