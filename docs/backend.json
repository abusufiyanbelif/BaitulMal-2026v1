{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Institutional member account with role-based access controls.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "User", "Donor", "Beneficiary"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "email", "role", "status"]
    },
    "PendingVerification": {
      "title": "Pending Verification",
      "description": "A request to modify a record that requires multi-party approval.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "module": { "type": "string" },
        "targetId": { "type": "string" },
        "assignedVerifierIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Pending", "Partially Approved", "Approved", "Rejected"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Member profile registry."
    },
    "/pending_verifications/{id}": {
      "schema": "#/backend/entities/PendingVerification",
      "description": "Institutional audit and approval pipeline."
    },
    "/donors/{id}": {
      "schema": "object",
      "description": "Contributor identity registry."
    },
    "/donations/{id}": {
      "schema": "object",
      "description": "Verified financial contribution logs."
    },
    "/beneficiaries/{id}": {
      "schema": "object",
      "description": "Master aid recipient registry."
    }
  }
}
