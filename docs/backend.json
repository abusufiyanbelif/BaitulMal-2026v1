{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Organizational member account details including roles and granular permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User", "Donor", "Beneficiary"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "permissions": { "type": "object" },
        "organizationGroup": { "type": "string" },
        "organizationRole": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status"]
    },
    "Donation": {
      "title": "Donation Record",
      "description": "Financial contribution record tracked against donors and initiatives.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Canceled", "Rejected"] },
        "donationDate": { "type": "string", "format": "date" },
        "linkSplit": { "type": "array" }
      },
      "required": ["id", "donorName", "amount", "status", "donationDate"]
    },
    "VerificationRequest": {
      "title": "Pending Verification",
      "description": "A staged modification request awaiting administrative or peer approval.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "module": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Partially Approved", "Approved", "Rejected"] },
        "assignedVerifierIds": { "type": "array" }
      },
      "required": ["id", "targetId", "module", "status", "assignedVerifierIds"]
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Member profile registry."
    },
    "/donations/{donationId}": {
      "schema": { "$ref": "#/backend/entities/Donation" },
      "description": "Financial contribution ledger."
    },
    "/pending_verifications/{requestId}": {
      "schema": { "$ref": "#/backend/entities/VerificationRequest" },
      "description": "Approval pipeline for record modifications."
    }
  }
}
