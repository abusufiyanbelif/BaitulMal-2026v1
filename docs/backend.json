{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Organizational profile for staff, volunteers, and portal users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User", "Donor", "Beneficiary"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "organizationGroup": { "type": "string" },
        "organizationRole": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "Institutional projects like Ration Kits or Relief efforts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Upcoming", "Active", "Completed"] },
        "targetAmount": { "type": "number" },
        "collectedAmount": { "type": "number" }
      }
    },
    "Donation": {
      "title": "Donation",
      "description": "Verified financial contribution records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Canceled"] }
      }
    },
    "PendingVerification": {
      "title": "PendingVerification",
      "description": "Audit records for modifications awaiting administrative approval.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "module": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Partially Approved", "Approved", "Rejected"] },
        "assignedVerifierIds": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "Member profiles." },
    "/campaigns/{campaignId}": { "schema": { "$ref": "#/entities/Campaign" }, "description": "Project hubs." },
    "/donations/{donationId}": { "schema": { "$ref": "#/entities/Donation" }, "description": "Verified contributions." },
    "/pending_verifications/{requestId}": { "schema": { "$ref": "#/entities/PendingVerification" }, "description": "Approval pipeline." }
  }
}