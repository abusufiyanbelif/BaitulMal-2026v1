{
  "entities": {
    "Campaign": {
      "title": "Campaign",
      "description": "An institutional fundraising project.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Upcoming", "Active", "Completed"] },
        "targetAmount": { "type": "number" },
        "collectedAmount": { "type": "number" },
        "authenticityStatus": { "type": "string", "enum": ["Pending Verification", "Verified", "Rejected", "On Hold", "Need More Details"] },
        "publicVisibility": { "type": "string", "enum": ["Hold", "Ready to Publish", "Published"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Urgent"] }
      }
    },
    "PendingVerification": {
      "title": "Pending Verification",
      "description": "A request for institutional audit and approval of a record modification.",
      "type": "object",
      "properties": {
        "module": { "type": "string" },
        "targetId": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Partially Approved", "Approved", "Rejected"] },
        "assignedVerifierIds": { "type": "array", "items": { "type": "string" } },
        "requestedBy": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/campaigns/{campaignId}": {
      "schema": { "$ref": "#/backend/entities/Campaign" },
      "description": "Community projects collection."
    },
    "/pending_verifications/{requestId}": {
      "schema": { "$ref": "#/backend/entities/PendingVerification" },
      "description": "Organizational audit trail for sensitive modifications."
    }
  }
}
