
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Institutional member or donor account details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User", "Donor", "Beneficiary"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "permissions": { "type": "object" },
        "organizationGroup": { "type": "string" },
        "organizationRole": { "type": "string" },
        "userKey": { "type": "string" },
        "loginId": { "type": "string" }
      }
    },
    "PendingVerification": {
      "title": "Pending Verification",
      "description": "A request to update or create a record that requires institutional approval.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "targetCollection": { "type": "string" },
        "module": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Partially Approved", "Approved", "Rejected"] },
        "requestedBy": { 
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "assignedVerifiers": { "type": "array" },
        "assignedVerifierIds": { "type": "array" },
        "newValue": { "type": "object" },
        "originalValue": { "type": "object" },
        "revalidatePath": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Core identity registry for staff and donors."
    },
    "/donors/{donorId}": {
      "schema": { "type": "object" },
      "description": "Mirrored profile for community contributors."
    },
    "/donations/{donationId}": {
      "schema": { "type": "object" },
      "description": "Financial registry of verified and pending contributions."
    },
    "/pending_verifications/{id}": {
      "schema": { "$ref": "#/backend/entities/PendingVerification" },
      "description": "Staged record modifications awaiting audit."
    }
  }
}
