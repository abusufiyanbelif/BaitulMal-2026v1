{
  "entities": {
    "Donor": {
      "title": "Donor Profile",
      "description": "Institutional record of a charitable contributor.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "ifscCode": { "type": "string" },
        "upiId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["name", "phone"]
    },
    "Donation": {
      "title": "Donation Record",
      "description": "Financial entry for a verified contribution.",
      "type": "object",
      "properties": {
        "donorId": { "type": "string" },
        "amount": { "type": "number" },
        "donationDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Canceled"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/donors/{donorId}": {
      "schema": "#/entities/Donor",
      "description": "Verified contributor profiles."
    },
    "/donations/{donationId}": {
      "schema": "#/entities/Donation",
      "description": "Global financial logs."
    }
  }
}
