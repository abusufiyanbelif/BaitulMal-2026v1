{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Organizational member account including permissions and role mappings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "User", "Donor", "Beneficiary"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "permissions": { "type": "object" },
        "organizationGroup": { "type": "string" },
        "organizationRole": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status"]
    },
    "PendingVerification": {
      "title": "PendingVerification",
      "description": "Staged record modifications awaiting administrative sign-off.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "module": { "type": "string" },
        "targetId": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected", "Partially Approved"] },
        "requestedBy": { "type": "object" },
        "assignedVerifierIds": { "type": "array", "items": { "type": "string" } },
        "newValue": { "type": "object" },
        "originalValue": { "type": "object" }
      }
    },
    "Donation": {
      "title": "Donation",
      "description": "Financial contribution record with linked initiatives.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "donorName": { "type": "string" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Canceled", "Rejected"] },
        "typeSplit": { "type": "array" },
        "linkSplit": { "type": "array" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Primary user registry."
    },
    "/donors/{donorId}": {
      "schema": { "type": "object" },
      "description": "Contributor identity registry."
    },
    "/donations/{donationId}": {
      "schema": { "$ref": "#/backend/entities/Donation" },
      "description": "Financial transaction ledger."
    },
    "/pending_verifications/{requestId}": {
      "schema": { "$ref": "#/backend/entities/PendingVerification" },
      "description": "Institutional audit and approval pipeline."
    },
    "/campaigns/{campaignId}": {
      "schema": { "type": "object" },
      "description": "Organizational project hub."
    },
    "/leads/{leadId}": {
      "schema": { "type": "object" },
      "description": "Individual community appeals."
    },
    "/settings/{configId}": {
      "schema": { "type": "object" },
      "description": "Global institutional parameters."
    },
    "/user_lookups/{identifier}": {
      "schema": { "type": "object" },
      "description": "Authentication mapping for phone/id sign-in."
    }
  }
}