{
  "entities": {
    "Donor": {
      "title": "Donor Profile",
      "description": "Institutional record for a community contributor, including financial handles.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full legal name of the donor." },
        "phone": { "type": "string", "description": "Primary 10-digit mobile number." },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" },
        "bankName": { "type": "string", "description": "Preferred bank for transfers." },
        "accountNumber": { "type": "string" },
        "ifscCode": { "type": "string" },
        "upiId": { "type": "string", "description": "Personal UPI handle." },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "notes": { "type": "string" }
      },
      "required": ["name", "phone"]
    },
    "Donation": {
      "title": "Donation Record",
      "description": "Financial contribution log linked to donors and initiatives.",
      "type": "object",
      "properties": {
        "donorId": { "type": "string", "description": "ID of the linked Donor Profile." },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "donationDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Canceled"] }
      }
    }
  },
  "auth": {
    "providers": ["email/password"]
  },
  "firestore": {
    "/donors/{donorId}": {
      "schema": "#/entities/Donor",
      "description": "Master registry of verified donor profiles."
    },
    "/donations/{donationId}": {
      "schema": "#/entities/Donation",
      "description": "Verifiable contribution logs."
    }
  }
}