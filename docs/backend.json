{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Organizational member account with granular permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "permissions": { "type": "object" }
      }
    },
    "Donor": {
      "title": "Donor Profile",
      "description": "Master identity for community contributors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      }
    },
    "Donation": {
      "title": "Donation Record",
      "description": "Verified financial contribution logged in the registry.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Canceled"] },
        "donorId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Member accounts." },
    "/donors/{donorId}": { "schema": "Donor", "description": "Master donor registry." },
    "/donations/{donationId}": { "schema": "Donation", "description": "Verified contribution logs." },
    "/settings/branding": { "schema": "object", "description": "App visual identity." },
    "/settings/payment": { "schema": "object", "description": "Bank and UPI configuration." }
  }
}