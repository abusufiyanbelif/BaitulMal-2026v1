{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Organizational staff member profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "loginId": { "type": "string" },
        "userKey": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User", "Donor", "Beneficiary"] },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "permissions": { "type": "object" },
        "organizationGroup": { "type": "string" },
        "organizationRole": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "Large-scale relief project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Upcoming", "Active", "Completed"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Urgent"] },
        "targetAmount": { "type": "number" },
        "collectedAmount": { "type": "number" },
        "publicVisibility": { "type": "string", "enum": ["Hold", "Ready to Publish", "Published"] }
      },
      "required": ["id", "name", "status"]
    },
    "Donation": {
      "title": "Donation",
      "description": "A financial contribution record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Verified", "Pending", "Canceled", "Rejected"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Institutional user accounts."
    },
    "/campaigns/{campaignId}": {
      "schema": { "$ref": "#/entities/Campaign" },
      "description": "Relief projects."
    },
    "/donations/{donationId}": {
      "schema": { "$ref": "#/entities/Donation" },
      "description": "Financial records."
    },
    "/pending_verifications/{requestId}": {
      "schema": "object",
      "description": "Audit staging area."
    }
  }
}
