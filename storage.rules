rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Public branding & payment artifacts
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaign artifacts (Publicly readable if initiative is Published)
    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || isAdmin();
      allow write: if isAdmin();
    }

    // Lead artifacts (Publicly readable if initiative is Published)
    match /leads/{leadId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || isAdmin();
      allow write: if isAdmin();
    }

    // User private artifacts (ID Proofs)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    // Beneficiary private artifacts (Strictly Admin or Registration Upload)
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }
    
    // Donation screenshots (High-privacy financial evidence)
    match /donations/{donationId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }
  }
}