
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocRef() {
        return /databases/(default)/documents/users/$(request.auth.uid);
    }
    
    function userExists() {
        return firestore.exists(userDocRef());
    }

    function getUserData() {
        return firestore.get(userDocRef()).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             userExists() &&
             getUserData().get('role', 'User').lower() == 'admin';
    }
    
    function hasPermission(module, permission) {
        let data = getUserData();
        return isSignedIn() && 
               userExists() &&
               (
                 isAdmin() ||
                 (
                   'permissions' in data &&
                   module in data.permissions &&
                   data.permissions[module].get(permission, false) == true
                 )
               );
    }

    function hasSubmodulePermission(module, submodule, permission) {
        let data = getUserData();
        return isSignedIn() && 
               userExists() &&
               (
                 isAdmin() ||
                 hasPermission(module, permission) ||
                 (
                   'permissions' in data &&
                   module in data.permissions &&
                   submodule in data.permissions[module] &&
                   data.permissions[module][submodule].get(permission, false) == true
                 )
               );
    }
    
    // ----------------------------------------------------------------------
    // Path Rules
    // ----------------------------------------------------------------------

    match /donations/{donationId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
    }

    match /leads/{leadId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
    }
    
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    // Settings sub-folders
    match /settings/branding/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasSubmodulePermission('settings', 'app', 'update');
    }
    match /settings/payment/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasSubmodulePermission('settings', 'app', 'update');
    }
    match /settings/info/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasSubmodulePermission('settings', 'info', 'update');
    }
    
    // Fallback for root settings if any
    match /settings/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('settings', 'update');
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin() || hasPermission('users', 'update');
    }

    match /test/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin() || hasPermission('diagnostics', 'read');
    }
  }
}
