rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check role from Firestore
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return request.auth != null && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, permission) {
      let permissions = getUserData().permissions;
      return isAdmin() || (permissions != null && permissions.keys().contains(module) && permissions[module][permission] == true);
    }

    // --- Organization Artifacts ---

    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /campaigns/{campaignId}/{allPaths=**} {
      // Staff with module access or if the initiative is published
      allow read: if isAdmin() || hasPermission('campaigns', 'read');
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
    }

    match /leads/{leadId}/{allPaths=**} {
      allow read: if isAdmin() || hasPermission('leads-members', 'read');
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
    }

    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read: if isAdmin() || hasPermission('beneficiaries', 'read');
      allow write: if isAdmin() || hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update');
    }

    match /donations/{donationId}/{allPaths=**} {
      allow read: if isAdmin() || hasPermission('donations', 'read');
      allow write: if isAdmin() || hasPermission('donations', 'create') || hasPermission('donations', 'update');
    }
  }
}