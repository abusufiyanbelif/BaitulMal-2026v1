rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Note: This makes a cross-service call to Firestore.
      // Ensure Firestore rules allow admins to read their own user document.
      return exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
             get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Admins can read and write anything.
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /settings/{allPaths=**} {
      allow read: if true;
      // write is covered by global admin rule
    }

    match /campaigns/{campaignId}/{allPaths=**} {
       allow read: if true;
       // write is covered by global admin rule
    }

    match /leads/{leadId}/{allPaths=**} {
       allow read: if true;
       // write is covered by global admin rule
    }
    
    match /donations/{donationId}/{allPaths=**} {
       allow read: if true;
       allow write: if isSignedIn(); // Any signed-in user can upload donation proofs
    }

    match /users/{userId}/{allPaths=**} {
      // Users can manage their own files. Admin access is handled by the global rule.
      allow read, write: if isOwner(userId);
    }
    
     match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      // Only admins can manage master beneficiary files.
      allow read, write: if isAdmin();
    }
  }
}
