rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user data from Firestore
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if user is an Admin
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    // Settings: Publicly readable branding/payment info, only writable by Admin
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profile Files (ID Proofs)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Campaign Artifacts
    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if isSignedIn() || isAdmin();
      allow write: if isAdmin();
    }

    // Lead Artifacts
    match /leads/{leadId}/{allPaths=**} {
      allow read: if isSignedIn() || isAdmin();
      allow write: if isAdmin();
    }

    // Beneficiary ID Proofs
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read: if isSignedIn() || isAdmin();
      allow write: if isSignedIn();
    }

    // Donation Evidence (Screenshots)
    match /donations/{donationId}/{allPaths=**} {
      allow read: if isSignedIn() || isAdmin();
      allow write: if isSignedIn();
    }
  }
}