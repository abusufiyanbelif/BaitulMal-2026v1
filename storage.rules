rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getFirestoreUser() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getFirestoreUser().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getFirestoreUser().status == 'Active';
    }
    
    function hasModulePermission(module, action) {
      return isAdmin() || (isActive() && getFirestoreUser().permissions[module][action] == true);
    }

    // --- Path Rules ---

    // Branding & Settings (Publicly Readable)
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profile Artifacts (ID Proofs)
    match /users/{userId}/{fileName} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow write: if isAdmin() || (request.auth.uid == userId && isActive());
    }

    // Donor & Donation Proofs
    match /donations/{donationId}/{fileName} {
      allow read: if hasModulePermission('donations', 'read') || 
                   (isSignedIn() && request.auth.uid == donationId); // Linked donor access
      allow write: if hasModulePermission('donations', 'create') || 
                    hasModulePermission('donations', 'update');
    }

    // Beneficiary ID Artifacts
    match /beneficiaries/{benId}/{fileName} {
      allow read: if hasModulePermission('beneficiaries', 'read');
      allow write: if isActive(); // Members can upload during registration
    }

    // Campaign & Lead Documents
    match /campaigns/{initiativeId}/{allPaths=**} {
      allow read: if true; // Public initiatives
      allow write: if hasModulePermission('campaigns', 'update');
    }
    
    match /leads/{initiativeId}/{allPaths=**} {
      allow read: if true; // Public leads
      allow write: if hasModulePermission('leads-members', 'update');
    }
  }
}