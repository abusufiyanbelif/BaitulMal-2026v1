rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: Real-time Firestore visibility check
    function isCampaignPublished(id) {
      return firestore.get(/databases/(default)/documents/campaigns/$(id)).data.publicVisibility == 'Published';
    }
    function isLeadPublished(id) {
      return firestore.get(/databases/(default)/documents/leads/$(id)).data.publicVisibility == 'Published';
    }

    // Institutional Branding
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Campaign Artifacts
    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if isCampaignPublished(campaignId) || request.auth != null;
      allow write: if request.auth != null;
    }

    // Lead Artifacts
    match /leads/{leadId}/{allPaths=**} {
      allow read: if isLeadPublished(leadId) || request.auth != null;
      allow write: if request.auth != null;
    }

    // Private Registry Artifacts (PII)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /beneficiaries/{benId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /donations/{donId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}