rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function hasPermission(module, action) {
      let user = getUserData();
      return user.role == 'Admin' || (user.permissions != null && user.permissions[module][action] == true);
    }

    // --- STORAGE PATHS ---

    // App Branding
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Identifications
    match /users/{userId}/{fileName} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && isActive();
    }

    // Campaign Documents
    match /campaigns/{campaignId}/{allPaths=**} {
      // Allow read if published or user is staff
      allow read: if firestore.get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' ||
                   hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'update') && isActive();
    }

    // Lead Documents
    match /leads/{leadId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published' ||
                   hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'update') && isActive();
    }

    // Beneficiary Evidence
    match /beneficiaries/{beneficiaryId}/{fileName} {
      allow read: if hasPermission('beneficiaries', 'read') || 
                   (isSignedIn() && request.auth.uid == beneficiaryId);
      allow write: if isSignedIn() && isActive();
    }

    // Donation Proofs
    match /donations/{donationId}/{fileName} {
      allow read: if hasPermission('donations', 'read') || 
                   (isSignedIn() && request.auth.uid == firestore.get(/databases/(default)/documents/donations/$(donationId)).data.donorId);
      allow write: if isSignedIn() && isActive();
    }
  }
}