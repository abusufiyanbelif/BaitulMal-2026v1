rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function userDocRef() {
        return /databases/(default)/documents/users/$(request.auth.uid);
    }
    
    function userExists() {
        return firestore.exists(userDocRef());
    }

    function getUserData() {
        return firestore.get(userDocRef()).data;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             userExists() &&
             'role' in getUserData() &&
             getUserData().role.lower() == 'admin';
    }
    
    function hasPermission(module, permission) {
      return isSignedIn() && 
             userExists() &&
             'permissions' in getUserData() &&
             module in getUserData().permissions &&
             getUserData().permissions[module][permission] == true;
    }
    
    // ----------------------------------------------------------------------
    // Path Rules
    // ----------------------------------------------------------------------

    match /donations/{donationId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
    }

    match /leads/{leadId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
    }
    
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    match /settings/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('settings', 'update');
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin() || hasPermission('users', 'update');
    }

    match /test/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin() || hasPermission('diagnostics', 'read');
    }
  }
}
