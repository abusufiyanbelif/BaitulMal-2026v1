rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Branding and public artifacts
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Campaign files: Accessible if Published
    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Lead files: Accessible if Published
    match /leads/{leadId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Sensitive Transaction Proofs
    match /donations/{donationId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Personal ID Proofs
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth.uid == userId || request.auth != null;
      allow write: if request.auth.uid == userId;
    }
    
    // Beneficiary ID Proofs
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}