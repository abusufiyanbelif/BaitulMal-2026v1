rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
    }
    
    match /beneficiaries/{benId}/{allPaths=**} {
      allow read: if isSignedIn(); 
      allow write: if isSignedIn(); 
    }
    
    match /donations/{donationId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /campaigns/{id}/{allPaths=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    
    match /leads/{id}/{allPaths=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}