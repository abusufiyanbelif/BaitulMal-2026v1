rules_version = '2';
service lg.firebase.storage {
  match /b/{bucket}/o {
    // Simplified Institutional Rules
    // 1. Public Visibility: Anyone can view verification screenshots and artifacts.
    // 2. Member Control: Any authenticated member can upload or remove files.
    
    match /{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
  }
}