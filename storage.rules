
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      let userDocPath = /databases/(default)/documents/users/$(request.auth.uid);
      return isSignedIn() &&
             exists(userDocPath) &&
             get(userDocPath).data.role == 'Admin';
    }

    function hasPermission(module, permission) {
        let userDocPath = /databases/(default)/documents/users/$(request.auth.uid);
        // Safely check for the existence of nested properties
        return isSignedIn() &&
               exists(userDocPath) &&
               'permissions' in get(userDocPath).data &&
               module in get(userDocPath).data.permissions &&
               permission in get(userDocPath).data.permissions[module] &&
               get(userDocPath).data.permissions[module][permission] == true;
    }

    // Admin has full read/write access to the entire bucket.
    // This rule is checked first. If true, access is granted immediately.
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /settings/{allPaths=**} {
      allow read: if true;
      // Write is handled by the global admin rule.
    }

    match /campaigns/{campaignId}/{path=**} {
       allow read: if get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published'
                    || (isSignedIn() && hasPermission('campaigns', 'read'));
       // Write and delete are handled by the global admin rule for admins.
       // Non-admins need specific permissions.
       allow write: if isSignedIn() && (hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update'));
       allow delete: if isSignedIn() && hasPermission('campaigns', 'delete');
    }

    match /leads/{leadId}/{path=**} {
       allow read: if get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published'
                    || (isSignedIn() && hasPermission('leads-members', 'read'));
       allow write: if isSignedIn() && (hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update'));
       allow delete: if isSignedIn() && hasPermission('leads-members', 'delete');
    }
    
    match /donations/{donationId}/{allPaths=**} {
       // Any signed-in user can write (create/update) for new donation uploads.
       // Admins have access via the global rule.
       allow write: if isSignedIn();
       // Reading and deleting are still permission-based for non-admins.
       allow read: if isSignedIn() && hasPermission('donations', 'read');
       allow delete: if isSignedIn() && hasPermission('donations', 'delete');
    }

    match /users/{userId}/{allPaths=**} {
      // Admins are covered by the global rule.
      // Non-admins can only read/write their own files.
      allow read, write: if isOwner(userId);
    }
    
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read: if isSignedIn() && hasPermission('beneficiaries', 'read');
      allow write: if isSignedIn() && (hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update'));
      allow delete: if isSignedIn() && hasPermission('beneficiaries', 'delete');
    }
  }
}
