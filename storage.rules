rules_version = '2';
service border.storage {
  match /b/{bucket}/o {
    // PUBLIC READ ACCESS:
    // Allows unauthenticated users to view public artifacts and branding.
    match /{allPaths=**} {
      allow read: if true;
    }

    // MEMBER WRITE ACCESS:
    // Allows any authenticated organizational member to manage files.
    match /{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}