rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Use `exists` to prevent errors on non-existent user docs
    function userExists() {
      return exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userExists() && getUserData().role == 'Admin';
    }

    // Use `userExists` to make this safer
    function hasPermission(module, permission) {
        return isSignedIn() &&
               userExists() &&
               'permissions' in getUserData() &&
               module in getUserData().permissions &&
               permission in getUserData().permissions[module] &&
               getUserData().permissions[module][permission] == true;
    }

    // Settings are public read, but only admin write.
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /campaigns/{campaignId}/{path=**} {
       allow read: if get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published'
                    || (isSignedIn() && hasPermission('campaigns', 'read')) || isAdmin();
       allow write: if (isSignedIn() && (hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update'))) || isAdmin();
       allow delete: if (isSignedIn() && hasPermission('campaigns', 'delete')) || isAdmin();
    }

    match /leads/{leadId}/{path=**} {
       allow read: if get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published'
                    || (isSignedIn() && hasPermission('leads-members', 'read')) || isAdmin();
       allow write: if (isSignedIn() && (hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update'))) || isAdmin();
       allow delete: if (isSignedIn() && hasPermission('leads-members', 'delete')) || isAdmin();
    }
    
    match /donations/{donationId}/{allPaths=**} {
      // A user can create a file if they are the owner specified in the metadata.
      allow create: if request.auth.uid == request.resource.customMetadata.ownerId || isAdmin();
      
      allow read: if (isSignedIn() && hasPermission('donations', 'read')) || isAdmin();
      allow update: if (isSignedIn() && hasPermission('donations', 'update')) || isAdmin(); // For metadata updates
      allow delete: if (isSignedIn() && hasPermission('donations', 'delete')) || isAdmin();
    }

    match /users/{userId}/{allPaths=**} {
      // Admins have access, non-admins can only access their own files.
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read: if (isSignedIn() && hasPermission('beneficiaries', 'read')) || isAdmin();
      allow write: if (isSignedIn() && (hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update'))) || isAdmin();
      allow delete: if (isSignedIn() && hasPermission('beneficiaries', 'delete')) || isAdmin();
    }
  }
}
