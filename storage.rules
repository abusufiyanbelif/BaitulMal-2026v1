
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getFirestoreData(path) {
      return get(/databases/(default)/documents/$(path)).data;
    }

    function isAdmin() {
      return isSignedIn() && getFirestoreData("users/" + request.auth.uid).role == 'Admin';
    }

    function hasPermission(module, permission) {
        return isSignedIn() && getFirestoreData("users/" + request.auth.uid).permissions[module][permission] == true;
    }

    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /campaigns/{campaignId}/{path=**} {
       allow read: if getFirestoreData("campaigns/" + campaignId).publicVisibility == 'Published'
                    || (isSignedIn() && (isAdmin() || hasPermission('campaigns', 'read')));
       allow write: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update'));
       allow delete: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'delete'));
    }

    match /leads/{leadId}/{path=**} {
       allow read: if getFirestoreData("leads/" + leadId).publicVisibility == 'Published'
                    || (isSignedIn() && (isAdmin() || hasPermission('leads-members', 'read')));
       allow write: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update'));
       allow delete: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'delete'));
    }
    
    match /donations/{donationId}/{allPaths=**} {
       // Only authenticated users can create (upload files for new donations).
       // Reading and deleting files requires specific permissions or admin role.
       allow create: if isSignedIn();
       allow read: if isSignedIn() && (isAdmin() || hasPermission('donations', 'read'));
       allow delete: if isSignedIn() && (isAdmin() || hasPermission('donations', 'delete'));
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'read'));
      allow write: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'delete'));
    }
  }
}
