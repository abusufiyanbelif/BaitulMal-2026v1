rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
             get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Admins can read and write anything.
    match /{allPaths=**} {
      allow write: if isAdmin();
    }

    match /settings/{allPaths=**} {
      allow read: if true;
    }

    match /campaigns/{campaignId}/{allPaths=**} {
       allow read: if true;
    }

    match /leads/{leadId}/{allPaths=**} {
       allow read: if true;
    }
    
    match /donations/{donationId}/{allPaths=**} {
       allow read: if true;
       allow write: if isSignedIn(); // Any signed-in user can upload donation proofs
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
     match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
