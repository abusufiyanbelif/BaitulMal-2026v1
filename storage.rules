rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function hasPermission(module, action) {
      let data = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      return data.role == 'Admin' || (data.permissions[module] != null && data.permissions[module][action] == true);
    }

    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || (isSignedIn() && hasPermission('campaigns', 'read'));
      allow write: if isAdmin() || hasPermission('campaigns', 'write');
    }

    match /leads/{leadId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || (isSignedIn() && hasPermission('leads-members', 'read'));
      allow write: if isAdmin() || hasPermission('leads-members', 'write');
    }

    match /beneficiaries/{benId}/{allPaths=**} {
      allow read: if isSignedIn() && hasPermission('beneficiaries', 'read');
      allow write: if isSignedIn();
    }

    match /donations/{donId}/{allPaths=**} {
      allow read: if isSignedIn() && hasPermission('donations', 'read');
      allow write: if isSignedIn();
    }
  }
}