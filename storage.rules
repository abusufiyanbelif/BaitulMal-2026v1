rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getFirestoreUser(userId) {
      return get(/databases/(default)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && getFirestoreUser(request.auth.uid).role == 'Admin';
    }

    function hasPermission(module, permission) {
        return isSignedIn() && getFirestoreUser(request.auth.uid).permissions[module][permission] == true;
    }

    // Admins can read and write anything.
    match /{allPaths=**} {
      allow write: if isAdmin();
    }

    match /settings/{allPaths=**} {
      allow read: if true;
    }

    match /campaigns/{campaignId}/{allPaths=**} {
       allow read: if get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published';
       allow write: if isAdmin() || hasPermission('campaigns', 'update');
    }

    match /leads/{leadId}/{allPaths=**} {
       allow read: if get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published';
       allow write: if isAdmin() || hasPermission('leads-members', 'update');
    }
    
    match /donations/{donationId}/{allPaths=**} {
       allow read: if isAdmin() || hasPermission('donations', 'read') || isOwner(get(/databases/(default)/documents/donations/$(donationId)).data.uploadedById);
       allow write: if isSignedIn(); // Any signed-in user can upload donation proofs
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
     match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
