rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Public Branding
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Initiative Assets - Accessible if published
    match /campaigns/{id}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /leads/{id}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Protected Registry Artifacts
    match /beneficiaries/{id}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /users/{id}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == id);
    }
    
    match /donations/{id}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}