rules_version = '2';
service map.storage {
  match /b/{bucket}/o {
    // Simplified Storage Access Model
    // 1. Public Transparency: All artifacts are readable by the public.
    // 2. Member Control: Authenticated members can manage all verification evidence and files.
    
    match /{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
  }
}