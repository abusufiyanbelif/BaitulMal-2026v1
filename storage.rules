rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, perm) {
      return isSignedIn() && (isAdmin() || (getUserData().permissions.keys().contains(module) && getUserData().permissions[module][perm] == true));
    }

    // --- RULES ---

    // App Branding & Settings (Public Read)
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Identification Artifacts
    match /users/{userId}/{allPaths=**} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Campaign Header Images & Documents
    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if hasPermission('campaigns', 'read') 
                  || firestore.get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published';
      allow write: if hasPermission('campaigns', 'update');
    }

    // Lead Appeal Header Images & Documents
    match /leads/{leadId}/{allPaths=**} {
      allow read: if hasPermission('leads-members', 'read') 
                  || firestore.get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published';
      allow write: if hasPermission('leads-members', 'update');
    }

    // Beneficiary Identification Artifacts
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'update') || hasPermission('beneficiaries', 'create');
    }

    // Donation Payment Screenshots
    match /donations/{donationId}/{allPaths=**} {
      allow read: if hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'update') || hasPermission('donations', 'create') || true; // Allow public uploads for new donations
    }
  }
}