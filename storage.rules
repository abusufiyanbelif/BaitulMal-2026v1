rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || isAdmin();
      allow write: if isAdmin();
    }

    match /leads/{leadId}/{allPaths=**} {
      allow read: if firestore.get(/databases/(default)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || isAdmin();
      allow write: if isAdmin();
    }

    match /beneficiaries/{benId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }

    match /donations/{donId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }
  }
}