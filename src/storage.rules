
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow any authenticated user to read and write to storage.
      // Security is primarily handled by Firestore rules, which control
      // the creation of links to these stored files.
      allow read, write: if request.auth != null;
    }
  }
}

    