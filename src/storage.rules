
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ----------------------------------------------------------------------
    // Helper Functions (Synced with firestore.rules)
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
        return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    
    function userExists() {
        return firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isSignedIn() && 
             userExists() &&
             getUserData().get('role', 'User').lower() == 'admin';
    }
    
    function hasPermission(module, permission) {
        let data = getUserData();
        return isSignedIn() && 
               userExists() &&
               (
                 isAdmin() ||
                 (
                   'permissions' in data &&
                   module in data.permissions &&
                   data.permissions[module].get(permission, false) == true
                 )
               );
    }

    function hasSubmodulePermission(module, submodule, permission) {
        let data = getUserData();
        return isSignedIn() && 
               userExists() &&
               (
                 isAdmin() ||
                 (
                   'permissions' in data &&
                   module in data.permissions &&
                   submodule in data.permissions[module] &&
                   data.permissions[module][submodule].get(permission, false) == true
                 )
               );
    }
    
    // ----------------------------------------------------------------------
    // Path Rules
    // ----------------------------------------------------------------------

    // Donations: Authenticated users can upload. Public can read.
    match /donations/{donationId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Campaigns & Leads: Access tied to submodule permissions.
    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
    }

    match /leads/{leadId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
    }
    
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    // Settings: Granular permissions for branding (app), donation info (info), and payments (app).
    match /settings/logo {
        allow read: if true;
        allow write: if isAdmin() || hasSubmodulePermission('settings', 'app', 'update');
    }
    match /settings/payment_qr {
        allow read: if true;
        allow write: if isAdmin() || hasSubmodulePermission('settings', 'app', 'update');
    }
    match /settings/donation_types/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasSubmodulePermission('settings', 'info', 'update');
    }
    match /settings/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('settings', 'update');
    }

    // User-specific files
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin() || hasPermission('users', 'update');
    }

    // Diagnostics
    match /test/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin() || hasPermission('diagnostics', 'read');
    }
  }
}
