
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // This rule allows any authenticated user to read and write to any file.
    // This is simpler for development but you may want to restrict this further
    // for production by adding more specific rules per path.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
