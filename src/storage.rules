
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Default rule: allows read and write access to all users.
    // You can replace this with more granular rules as needed.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Example of a more restrictive rule for user-specific data
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
