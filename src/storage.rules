
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ----------------------------------------------------------------------
    // Helper Functions (Synced with firestore.rules)
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function userDocRef() {
        // Note: In Storage Rules, `database` is not a predefined variable.
        // We must explicitly use `(default)`.
        return /databases/(default)/documents/users/$(request.auth.uid);
    }
    
    function userExists() {
        return exists(userDocRef());
    }

    function getUserData() {
        return get(userDocRef()).data;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             userExists() &&
             'role' in getUserData() &&
             getUserData().role.lower() == 'admin';
    }
    
    function hasPermission(module, permission) {
      return isSignedIn() && 
             userExists() &&
             'permissions' in getUserData() &&
             module in getUserData().permissions &&
             getUserData().permissions[module][permission] == true;
    }
    
    // ----------------------------------------------------------------------
    // Path Rules
    // ----------------------------------------------------------------------

    // Donations: Authenticated users can upload. Public can read (if URL is known).
    match /donations/{donationId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Campaigns: Must be admin or have campaign update permissions to write.
    match /campaigns/{campaignId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
    }

    // Leads: Must be admin or have lead update permissions to write.
    match /leads/{leadId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
    }
    
    // Master Beneficiaries: Must be admin or have specific beneficiary permissions to write.
    match /beneficiaries/{beneficiaryId}/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    // Settings: Publicly readable (for logo), but only writable by admins/settings managers.
    match /settings/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('settings', 'update');
    }

    // User-specific files: Only the owner or an admin/user with permissions can write.
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin() || hasPermission('users', 'update');
    }

    // Diagnostics path for testing: Only owner can access.
    match /test/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin() || hasPermission('diagnostics', 'read');
    }
  }
}
