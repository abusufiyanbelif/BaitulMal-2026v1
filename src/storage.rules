
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Only authenticated users can upload donation files.
    // Public read access is maintained for receipt images.
    match /donations/{donationId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /campaigns/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /leads/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /beneficiaries/{allPaths=**} {
        allow read: if true;
        allow write: if isSignedIn();
    }

    // Settings can be read by anyone (for logo), but only written by auth'd users.
    match /settings/{allPaths=**} {
        allow read: if true;
        allow write: if isSignedIn();
    }

    // User-specific files can only be written by the user themselves.
    // Reads are open for simplicity, assuming URLs are not guessable.
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Diagnostics path for testing
    match /test/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
