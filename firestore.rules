rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DocuExtract Security Rules Documentation
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict User-Ownership model. Access to data is gated primarily 
     * by the user's identity as established by the document path. The system is designed 
     * for "Authorization Independence," meaning documents contain denormalized IDs (like ownerId) 
     * to allow security checks to perform at high speed without recursive database lookups (get() calls).
     *
     * DATA STRUCTURE:
     * All application data is hierarchical and nested under a specific user:
     * /users/{userId}/documents/{documentId}/[sub-collections]
     *
     * KEY SECURITY DECISIONS:
     * 1. Strict Ownership: Users can only read, list, or modify data within their own /users/{userId} path.
     * 2. Relational Integrity: On creation, documents must include IDs that match their URL path.
     * 3. Immutability: Critical relationship fields (ownerId, documentId, billingDetailsId) are 
     *    immutable once created to prevent data being "moved" between users or parents.
     * 4. Prototyping Flexibility: While authorization is strictly enforced, the specific shape 
     *    and data types of content fields (like file names or extracted text) are not validated 
     *    to allow for rapid schema iteration.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Combines existence check and ownership for updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root user document.
     * @path /users/{userId}
     * @allow (get, list, create) if userId matches auth.uid.
     * @deny (all) if userId does not match auth.uid.
     * @principle Pattern 4: Self-Creation and Ownership.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Rules for documents uploaded for processing.
       * @path /users/{userId}/documents/{documentId}
       * @allow (create) if auth.uid == userId and data.ownerId == userId.
       * @deny (update) if ownerId is changed.
       * @principle Pattern 1: Ownership with relational validation.
       */
      match /documents/{documentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) 
                      && request.resource.data.id == documentId
                      && request.resource.data.ownerId == userId;
        allow update: if isExistingOwner(userId)
                      && request.resource.data.ownerId == resource.data.ownerId
                      && request.resource.data.id == resource.data.id;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for raw and edited extraction results.
         * @path /users/{userId}/documents/{documentId}/textExtractionResults/{resultId}
         * @allow (create) if ownerId and documentId in data match the path.
         * @principle Relational integrity between nested subcollections and parents.
         */
        match /textExtractionResults/{resultId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId)
                        && request.resource.data.ownerId == userId
                        && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId)
                        && request.resource.data.ownerId == resource.data.ownerId
                        && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for structured identity proof data.
         * @path /users/{userId}/documents/{documentId}/identityProofDetails/{idProofId}
         */
        match /identityProofDetails/{idProofId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId)
                        && request.resource.data.ownerId == userId
                        && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId)
                        && request.resource.data.ownerId == resource.data.ownerId
                        && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for medical report extractions.
         * @path /users/{userId}/documents/{documentId}/medicalReportDetails/{medicalId}
         */
        match /medicalReportDetails/{medicalId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId)
                        && request.resource.data.ownerId == userId
                        && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId)
                        && request.resource.data.ownerId == resource.data.ownerId
                        && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for billing headers and summaries.
         * @path /users/{userId}/documents/{documentId}/billingDetails/{billingId}
         */
        match /billingDetails/{billingId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId)
                        && request.resource.data.ownerId == userId
                        && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId)
                        && request.resource.data.ownerId == resource.data.ownerId
                        && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);

          /**
           * @description Rules for specific line items within a bill.
           * @path /users/{userId}/documents/{documentId}/billingDetails/{billingId}/lineItems/{itemId}
           * @principle Triple-link validation (User -> Document -> Bill).
           */
          match /lineItems/{itemId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId)
                          && request.resource.data.ownerId == userId
                          && request.resource.data.documentId == documentId
                          && request.resource.data.billingDetailsId == billingId;
            allow update: if isExistingOwner(userId)
                          && request.resource.data.ownerId == resource.data.ownerId
                          && request.resource.data.documentId == resource.data.documentId
                          && request.resource.data.billingDetailsId == resource.data.billingDetailsId;
            allow delete: if isExistingOwner(userId);
          }
        }
      }
    }
  }
}