rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, action) {
      return isSignedIn() && (isAdmin() || getUserData().permissions[module][action] == true);
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || hasPermission('users', 'create') || hasPermission('users', 'update') || hasPermission('users', 'delete');
    }

    match /user_lookups/{lookupId} {
      allow read: if true; // Needed for sign-in process
      allow write: if isAdmin() || hasPermission('users', 'create') || hasPermission('users', 'update');
    }

    match /campaigns/{campaignId} {
      allow read: if true; // Public listings are filtered by client query (Published + Verified)
      allow create, update, delete: if isAdmin() || hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update') || hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || hasPermission('campaigns.beneficiaries', 'create') || hasPermission('campaigns.beneficiaries', 'update') || hasPermission('campaigns.beneficiaries', 'delete');
      }
    }

    match /leads/{leadId} {
      allow read: if true; // Public listings are filtered by client query (Published + Verified)
      allow create, update, delete: if isAdmin() || hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update') || hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || hasPermission('leads-members.beneficiaries', 'create') || hasPermission('leads-members.beneficiaries', 'update') || hasPermission('leads-members.beneficiaries', 'delete');
      }
    }

    match /beneficiaries/{beneficiaryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update') || hasPermission('beneficiaries', 'delete');
    }

    match /donations/{donationId} {
      // Allow public read only for verified donations to show progress bars
      // Filtering must happen on the client
      allow read: if true; 
      allow create, update, delete: if isAdmin() || hasPermission('donations', 'create') || hasPermission('donations', 'update') || hasPermission('donations', 'delete');
    }

    match /donors/{donorId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || hasPermission('donors', 'create') || hasPermission('donors', 'update') || hasPermission('donors', 'delete');
    }

    match /settings/{settingId} {
      allow read: if true; // Public settings (branding, payment info)
      allow write: if isAdmin() || hasPermission('settings', 'update');
    }
    
    match /page_hits/{pageId} {
      allow read: if isSignedIn();
      allow write: if true; // Public analytics incrementing
    }
  }
}
