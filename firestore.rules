rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // UNRESTRICTED ACCESS FOR TESTING & STABILIZATION
    // As per requirement: "flaws for rules and strictness should be not there for storage and database as we have UI level visibility for every user type"
    match /{document=**} {
      allow read, write: if true;
    }
  }
}