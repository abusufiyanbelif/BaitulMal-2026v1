rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Centralized Security Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function hasPermission(module, action) {
      let perms = getUserData().permissions;
      return isAdmin() || (isActive() && perms[module][action] == true);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isActive() && request.auth.uid == userId);
    }
    
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'update');
      allow create: if hasPermission('donors', 'create');
      allow delete: if hasPermission('donors', 'delete');
    }
    
    match /donations/{donationId} {
      allow read: if true; // Public stats and verification tickers
      allow write: if hasPermission('donations', 'update');
      allow create: if true; // Public donation gateway
      allow delete: if hasPermission('donations', 'delete');
    }
    
    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'update');
      allow create: if hasPermission('beneficiaries', 'create');
      allow delete: if hasPermission('beneficiaries', 'delete');
    }
    
    match /campaigns/{id} {
      allow read: if true;
      allow write: if hasPermission('campaigns', 'update');
    }
    
    match /campaigns/{id}/beneficiaries/{benId} {
      allow read: if true;
      allow write: if hasPermission('campaigns', 'update');
    }
    
    match /leads/{id} {
      allow read: if true;
      allow write: if hasPermission('leads-members', 'update');
    }
    
    match /leads/{id}/beneficiaries/{benId} {
      allow read: if true;
      allow write: if hasPermission('leads-members', 'update');
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- Verification Pipeline Rules ---
    // Critical: Align with 'assignedVerifierIds' query logic
    
    match /pending_verifications/{id} {
      allow list: if isAdmin() || (isSignedIn() && isActive() && request.auth.uid in request.query.filters.assignedVerifierIds);
      allow get: if isAdmin() || (isSignedIn() && isActive() && request.auth.uid in resource.data.assignedVerifierIds);
      allow create: if isSignedIn() && isActive();
      allow update: if isAdmin() || (isSignedIn() && isActive() && request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }
    
    match /page_hits/{id} {
      allow read, write: if true;
    }
  }
}
