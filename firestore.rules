/**
 * Core Philosophy: This ruleset enforces a strict user-ownership security model. All application data, including user profiles, uploaded documents, and their extracted content, is considered private. A user can only access data that exists within their own designated data tree, identified by their unique user ID.
 *
 * Data Structure: The entire data model is hierarchical, starting with a top-level `users` collection. Each user has a single document in this collection, where the document ID matches their Firebase Authentication UID. All subsequent data, such as documents and extractions, are stored in subcollections under this user-specific document (e.g., `/users/{userId}/documents/{documentId}`). This structure is fundamental to the security model.
 *
 * Key Security Decisions:
 * - User Privacy: There are no public collections. All data is private to the owning user.
 * - No User Enumeration: Listing the top-level `/users` collection is explicitly disallowed to prevent malicious actors from discovering the application's user base.
 * - Path-Based Authorization: Security decisions are made primarily using the document's path. This is highly performant as it avoids costly database lookups (`get()` calls) to other documents to verify permissions.
 *
 * Denormalization for Authorization: The core security strategy relies on the data's path. By placing all of a user's data under `/users/{userId}`, we use the `{userId}` wildcard as a denormalized authorization key. The rules can simply compare this path segment to the authenticated user's ID (`request.auth.uid`) to grant or deny access, which is the most efficient method available in Firestore.
 *
 * Structural Segregation: The data is segregated by user at the highest level. Each user's data exists in a completely separate document tree. This clean separation prevents any possibility of data leakage between users and simplifies list queries, as any query will only ever operate on a single user's data partition.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Verifies that the request is coming from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's ID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for update/delete
     * operations to prevent acting on documents that don't exist.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * On create, validates that the UserProfile document's internal `id` field
     * matches the document's ID in the path (`userId`).
     */
    function isUserProfileDataConsistent(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * On update, ensures the UserProfile's `id` field is immutable.
     */
    function isUserProfileIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * On create, validates that the Document's internal `userId` field
     * matches the `userId` from the path.
     */
    function isDocumentDataConsistent(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * On update, ensures the Document's `userId` field is immutable.
     */
    function isDocumentUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    /**
     * On create, validates that an extraction's internal `documentId` field
     * matches the `documentId` from the path.
     */
    function isExtractionDataConsistent(documentId) {
      return request.resource.data.documentId == documentId;
    }

    /**
     * On update, ensures an extraction's `documentId` field is immutable.
     */
    function isExtractionDocIdImmutable() {
      return request.resource.data.documentId == resource.data.documentId;
    }

    /**
     * On create, validates that a Line Item's internal `billingExtractionId`
     * field matches the `billingExtractionId` from the path.
     */
    function isLineItemDataConsistent(billingExtractionId) {
      return request.resource.data.billingExtractionId == billingExtractionId;
    }

    /**
     * On update, ensures a Line Item's `billingExtractionId` field is immutable.
     */
    function isLineItemExtractionIdImmutable() {
      return request.resource.data.billingExtractionId == resource.data.billingExtractionId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own profile document.
     * @deny (list) Any user, to prevent enumeration of the user base.
     * @principle A user owns their profile. They can create, read, update, and delete it, but cannot see other users' profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && isUserProfileDataConsistent(userId);
      allow update: if isExistingOwner(userId) && isUserProfileIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to a user's uploaded documents.
     * @path /users/{userId}/documents/{documentId}
     * @allow (create) An authenticated user creating a document under their own profile.
     * @deny (get) A user trying to read a document belonging to another user.
     * @principle Restricts all access to the user's own data tree, enforcing strict data privacy.
     */
    match /users/{userId}/documents/{documentId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isDocumentDataConsistent(userId);
      allow update: if isExistingOwner(userId) && isDocumentUserIdImmutable();
      allow delete: if isExistingOwner(userId);

      /**
       * @description Controls access to identity proof extractions for a specific document.
       * @path /users/{userId}/documents/{documentId}/identityProofExtractions/{extractionId}
       * @allow (list) The document owner listing their own identity proof extractions.
       * @deny (create) Another user attempting to add an extraction to someone else's document.
       * @principle Inherits ownership from the parent document path, ensuring only the owner can manage their sensitive extracted data.
       */
      match /identityProofExtractions/{extractionId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isExtractionDataConsistent(documentId);
        allow update: if isExistingOwner(userId) && isExtractionDocIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Controls access to billing extractions for a specific document.
       * @path /users/{userId}/documents/{documentId}/billingExtractions/{extractionId}
       * @allow (get) The document owner reading their own billing extraction.
       * @deny (update) Another user attempting to modify an extraction on someone else's document.
       * @principle Inherits ownership from the parent document path, ensuring only the owner can manage their sensitive extracted data.
       */
      match /billingExtractions/{extractionId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isExtractionDataConsistent(documentId);
        allow update: if isExistingOwner(userId) && isExtractionDocIdImmutable();
        allow delete: if isExistingOwner(userId);

        /**
         * @description Controls access to line items within a billing extraction.
         * @path /users/{userId}/documents/{documentId}/billingExtractions/{billingExtractionId}/lineItems/{lineItemId}
         * @allow (delete) The document owner deleting a line item from their billing extraction.
         * @deny (get) Any user trying to access a line item belonging to another user.
         * @principle Deeply nested ownership is enforced by checking the top-level `userId` in the path.
         */
        match /lineItems/{lineItemId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && isLineItemDataConsistent(extractionId);
          allow update: if isExistingOwner(userId) && isLineItemExtractionIdImmutable();
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Controls access to medical report extractions for a specific document.
       * @path /users/{userId}/documents/{documentId}/medicalReportExtractions/{extractionId}
       * @allow (create) The document owner creating a new medical extraction record.
       * @deny (list) Another user trying to list extractions from someone else's document.
       * @principle Inherits ownership from the parent document path, ensuring only the owner can manage their sensitive extracted data.
       */
      match /medicalReportExtractions/{extractionId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isExtractionDataConsistent(documentId);
        allow update: if isExistingOwner(userId) && isExtractionDocIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}