
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasPermission(module, action) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.role == 'Admin' || (user.permissions != null && user.permissions[module] != null && user.permissions[module][action] == true);
    }

    function isPublished(docId, type) {
      return get(/databases/$(database)/documents/$(type)/$(docId)).data.publicVisibility == 'Published';
    }

    // Users & Authentication Mapping
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || hasPermission('users', 'read'));
      allow write: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions']));
    }
    
    match /user_lookups/{lookupId} {
      allow read: if true; // Public lookup for login
      allow write: if isAdmin();
    }

    // Campaigns Module
    match /campaigns/{campaignId} {
      allow read: if isSignedIn() || resource.data.publicVisibility == 'Published';
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if isSignedIn() || isPublished(campaignId, 'campaigns');
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }

    // Leads Module
    match /leads/{leadId} {
      allow read: if isSignedIn() || resource.data.publicVisibility == 'Published';
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if isSignedIn() || isPublished(leadId, 'leads');
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    // Master Beneficiaries Registry
    match /beneficiaries/{beneficiaryId} {
      allow read: if isSignedIn() && hasPermission('beneficiaries', 'read');
      allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    // Donors Registry
    match /donors/{donorId} {
      allow read: if isSignedIn() && hasPermission('donors', 'read');
      allow write: if isAdmin() || hasPermission('donors', 'update');
    }

    // Global Donations Registry
    match /donations/{donationId} {
      allow read: if isSignedIn() || resource.data.status == 'Verified';
      allow write: if isAdmin() || hasPermission('donations', 'update');
    }

    // System Settings & Info Pages
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Analytics (Page Hits)
    match /page_hits/{pageId} {
      allow read: if isAdmin();
      allow write: if true; // Publicly incrementable
    }
  }
}
