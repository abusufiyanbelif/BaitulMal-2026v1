rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, action) {
      return isAdmin() || (isSignedIn() && getUserData().permissions[module][action] == true);
    }

    // --- Campaigns ---
    match /campaigns/{campaignId} {
      // Public can read if Published
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'update');
      
      match /beneficiaries/{beneficiaryId} {
        // Public can read sub-list for summary breakdown if parent is Published
        allow read: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    // --- Leads ---
    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'update');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
        allow write: if hasPermission('leads-members', 'update');
      }
    }

    // --- Master Registries (Strictly Private) ---
    match /beneficiaries/{beneficiaryId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'write');
    }
    
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'write');
    }

    // --- Donations ---
    match /donations/{donationId} {
      // Verified donations are public for progress calculation metrics
      allow read: if resource.data.status == 'Verified' || hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'write');
    }

    // --- Users & Auth ---
    match /users/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || hasPermission('users', 'read') || (resource.data.organizationGroup != null && resource.data.status == 'Active');
      allow write: if isAdmin();
    }
    
    match /user_lookups/{lookupId} {
      allow read: if true; // Required for custom Login ID mechanism
    }

    // --- Settings & Analytics ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}