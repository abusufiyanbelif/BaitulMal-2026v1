rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Safely check for admin role. This prevents errors if the user document doesn't exist.
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function isUserProfileDataConsistent(userId) {
      return request.resource.data.id == userId;
    }

    function isUserProfileIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    function isDocumentDataConsistent(userId) {
      return request.resource.data.userId == userId;
    }

    function isDocumentUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    function isExtractionDataConsistent(documentId) {
      return request.resource.data.documentId == documentId;
    }

    function isExtractionDocIdImmutable() {
      return request.resource.data.documentId == resource.data.documentId;
    }

    function isLineItemDataConsistent(billingExtractionId) {
      return request.resource.data.billingExtractionId == billingExtractionId;
    }

    function isLineItemExtractionIdImmutable() {
      return request.resource.data.billingExtractionId == resource.data.billingExtractionId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_lookups/{lookupId} {
        allow read: if true;
        allow write: if isSignedIn() || isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();

      match /beneficiaries/{beneficiaryId} {
        allow read, write: if isAdmin();
      }
    }
    
    match /leads/{leadId} {
      allow read: if true;
      allow write: if isAdmin();

       match /beneficiaries/{beneficiaryId} {
        allow read, write: if isAdmin();
      }
    }
    
    match /donations/{donationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /beneficiaries/{beneficiaryId} {
      // Any signed-in user can read the master list, admins can write.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // Admins have full access.
      allow read, write: if isAdmin();
      
      // Non-admins can get, create, and update their own profile.
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isUserProfileDataConsistent(userId);
      allow update: if isOwner(userId) && isUserProfileIdImmutable();

      match /documents/{documentId} {
        allow get, list: if isOwner(userId);
        allow create: if (isOwner(userId) && isDocumentDataConsistent(userId));
        allow update: if (isOwner(userId) && isDocumentUserIdImmutable());
        allow delete: if isOwner(userId);

        match /identityProofExtractions/{extractionId} {
          allow get, list: if isOwner(userId);
          allow create: if (isOwner(userId) && isExtractionDataConsistent(documentId));
          allow update: if (isOwner(userId) && isExtractionDocIdImmutable());
          allow delete: if isOwner(userId);
        }

        match /billingExtractions/{extractionId} {
          allow get, list: if isOwner(userId);
          allow create: if (isOwner(userId) && isExtractionDataConsistent(documentId));
          allow update: if (isOwner(userId) && isExtractionDocIdImmutable());
          allow delete: if isOwner(userId);

          match /lineItems/{lineItemId} {
            allow get, list: if isOwner(userId);
            allow create: if (isOwner(userId) && isLineItemDataConsistent(extractionId));
            allow update: if (isOwner(userId) && isLineItemExtractionIdImmutable());
            allow delete: if isOwner(userId);
          }
        }

        match /medicalReportExtractions/{extractionId} {
          allow get, list: if isOwner(userId);
          allow create: if (isOwner(userId) && isExtractionDataConsistent(documentId));
          allow update: if (isOwner(userId) && isExtractionDocIdImmutable());
          allow delete: if isOwner(userId);
        }
      }
    }
  }
}
