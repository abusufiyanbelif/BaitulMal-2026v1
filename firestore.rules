
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function userExists() {
      return exists(userDoc(request.auth.uid));
    }

    function getUserData() {
        return get(userDoc(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             userExists() &&
             'role' in getUserData() &&
             (getUserData().role.lower() == 'admin');
    }

    function hasPermission(module, permission) {
        let data = getUserData();
        return isSignedIn() && 
               userExists() &&
               (
                 isAdmin() ||
                 (
                   'permissions' in data &&
                   module in data.permissions &&
                   permission in data.permissions[module] && 
                   data.permissions[module][permission] == true
                 )
               );
    }

    function hasSubmodulePermission(module, submodule, permission) {
        let data = getUserData();
        return isSignedIn() && 
               userExists() &&
               (
                 isAdmin() ||
                 (
                   'permissions' in data &&
                   module in data.permissions &&
                   submodule in data.permissions[module] && 
                   permission in data.permissions[module][submodule] && 
                   data.permissions[module][submodule][permission] == true
                 )
               );
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || 
                   hasPermission('settings', 'update') ||
                   (settingId == 'info' && hasSubmodulePermission('settings', 'info', 'update')) ||
                   (settingId == 'donationInfo' && hasSubmodulePermission('settings', 'info', 'update')) ||
                   (settingId == 'branding' && hasSubmodulePermission('settings', 'app', 'update')) ||
                   (settingId == 'payment' && hasSubmodulePermission('settings', 'app', 'update'));
    }
    
    match /page_hits/{pageId} {
        allow read: if hasPermission('analytics', 'read') || isAdmin();
        allow write: if true; 
    }

    match /user_lookups/{lookupId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'create'));
      allow update: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'update') || hasSubmodulePermission('campaigns', 'ration', 'update') || hasSubmodulePermission('campaigns', 'summary', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'delete'));

      match /beneficiaries/{beneficiaryId} {
        allow read: if true;
        allow create: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'beneficiaries', 'create'));
        allow update: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'beneficiaries', 'update'));
        allow delete: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'beneficiaries', 'delete'));
      }
      
      match /donations/{donationId} {
        allow read: if true;
        allow create: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'donations', 'create'));
        allow update: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'donations', 'update'));
        allow delete: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'donations', 'delete'));
      }
    }
    
    match /leads/{leadId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'create'));
      allow update: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'update') || hasSubmodulePermission('leads-members', 'summary', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'delete'));

       match /beneficiaries/{beneficiaryId} {
        allow read: if true;
        allow create: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'beneficiaries', 'create'));
        allow update: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'beneficiaries', 'update'));
        allow delete: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'beneficiaries', 'delete'));
      }
      
      match /donations/{donationId} {
        allow read: if true;
        allow create: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'donations', 'create'));
        allow update: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'donations', 'update'));
        allow delete: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'donations', 'delete'));
      }
    }
    
    match /donations/{donationId} {
      allow read: if true;
      allow create: if isSignedIn() || isAdmin();
      allow update: if isSignedIn() && (isAdmin() || isOwner(request.resource.data.uploadedById) || hasPermission('donations', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.uploadedById) || hasPermission('donations', 'delete'));
    }
    
    match /beneficiaries/{beneficiaryId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'create'));
      allow update: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'delete'));
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || hasPermission('users', 'read') || isAdmin();
      allow list: if hasPermission('users', 'read') || hasPermission('settings', 'update') || isAdmin();
      allow create: if isOwner(userId) || hasPermission('users', 'create') || isAdmin();
      allow update: if isOwner(userId) || hasPermission('users', 'update') || isAdmin();
      allow delete: if (request.auth.uid != userId && hasPermission('users', 'delete')) || (isAdmin() && request.auth.uid != userId);
    }
  }
}
