rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function hasPermission(module, action) {
      let permissions = getUserData().permissions;
      return isAdmin() || (isActive() && permissions[module][action] == true);
    }

    // ------------------------------------------------------------
    // Rules
    // ------------------------------------------------------------

    // Public lookups for login discovery
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings (Public & Admin restricted)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users & Members
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId) || hasPermission('users', 'read');
      allow create: if isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && isActive());
      allow delete: if isAdmin();
    }

    // Donors Registry
    match /donors/{donorId} {
      allow read: if isAdmin() || hasPermission('donors', 'read');
      allow write: if isAdmin() || hasPermission('donors', 'update');
    }

    // Master Beneficiaries
    match /beneficiaries/{beneficiaryId} {
      allow read: if isAdmin() || hasPermission('beneficiaries', 'read');
      allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    // Donations Central Log
    match /donations/{donationId} {
      allow read: if isAdmin() || hasPermission('donations', 'read');
      allow write: if isAdmin() || hasPermission('donations', 'update');
    }

    // Initiatives: Campaigns & Leads
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }

    match /leads/{leadId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    // Guidance Directory
    match /guidance/{resourceId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('guidance', 'update');
    }

    // Verification Pipeline (High-Integrity)
    match /pending_verifications/{requestId} {
      // Admins can see the full pipeline.
      // Members can only see verifications assigned specifically to them.
      // List rules must match the query filters.
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100 && request.auth.uid in request.query.filters[0].value);
      
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      
      allow create: if isActive();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }
    
    // Page Hits (Analytics)
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true; 
    }
  }
}
