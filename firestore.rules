rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function hasPermission(module, action) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.role == 'Admin' || user.permissions[module][action] == true;
    }

    // Public Visibility Helpers
    function isPublished(path) {
      return get(path).data.publicVisibility == 'Published';
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
    
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns
    match /campaigns/{campaignId} {
      allow read: if isPublished(/databases/$(database)/documents/campaigns/$(campaignId)) || hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update') || hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if isPublished(/databases/$(database)/documents/campaigns/$(campaignId)) || hasPermission('campaigns', 'beneficiaries.read');
        allow write: if hasPermission('campaigns', 'beneficiaries.create') || hasPermission('campaigns', 'beneficiaries.update') || hasPermission('campaigns', 'beneficiaries.delete');
      }
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isPublished(/databases/$(database)/documents/leads/$(leadId)) || hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update') || hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if isPublished(/databases/$(database)/documents/leads/$(leadId)) || hasPermission('leads-members', 'beneficiaries.read');
        allow write: if hasPermission('leads-members', 'beneficiaries.create') || hasPermission('leads-members', 'beneficiaries.update') || hasPermission('leads-members', 'beneficiaries.delete');
      }
    }

    // Donations
    match /donations/{donationId} {
      allow read: if (resource.data.status == 'Verified') || hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'create') || hasPermission('donations', 'update') || hasPermission('donations', 'delete');
    }

    // Donors
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'create') || hasPermission('donors', 'update') || hasPermission('donors', 'delete');
    }

    // Registry / Master Beneficiaries
    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update') || hasPermission('beneficiaries', 'delete');
    }
    
    // Page Hits / Analytics
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}