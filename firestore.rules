rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // ADMINISTRATIVE BYPASS: Recognize core team UIDs as superusers
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "cyMl1lQME0Yur1YS3VCms1AvrOJ2" || // System Admin
        request.auth.uid == "S5efNV5jpTPoxYNv6SnAlv3jNPO2" || // Abusufiyan Belif
        request.auth.uid == "3gKwUE2JrBT8wngoUxTTN6tLJk03" || // Maaz Shaikh
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin"
      );
    }

    function hasPermission(module, action) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAdmin() || (user.permissions[module][action] == true);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (request.auth.uid == userId);
    }

    match /user_lookups/{lookupId} {
      allow read: if true; // Publicly readable for login discovery
      allow write: if isAdmin();
    }

    match /donors/{donorId} {
      allow read: if isAdmin() || hasPermission('donors', 'read') || (request.auth.uid == donorId);
      allow write: if isAdmin() || hasPermission('donors', 'update');
    }

    match /donations/{donationId} {
      allow read: if true; // Summary logic requires listing verified donations
      allow write: if isAdmin() || hasPermission('donations', 'update') || (request.auth.uid == request.resource.data.donorId);
    }

    match /beneficiaries/{beneficiaryId} {
      allow read: if isAdmin() || hasPermission('beneficiaries', 'read');
      allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    match /campaigns/{campaignId} {
      allow read: if true; // Visibility controlled by publicVisibility field in UI logic
      allow write: if isAdmin() || hasPermission('campaigns', 'update');

      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }

    match /leads/{leadId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('leads-members', 'update');

      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    match /pending_verifications/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in request.resource.data.assignedVerifierIds || isAdmin());
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Public branding/payment settings
      allow write: if isAdmin();
    }

    match /page_hits/{pageId} {
      allow read, write: if true; // Anonymous analytics tracking
    }
  }
}