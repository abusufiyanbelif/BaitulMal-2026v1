rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Security Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function hasPermission(module, action) {
      let perms = getUserData().permissions;
      return isAdmin() || (isActive() && perms[module][action] == true);
    }

    // --- Module Rules ---

    // Branding and Info (Publicly Readable)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Identity Lookups (Publicly Readable for Login discovery)
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users & Members
    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId || hasPermission('users', 'read');
      allow write: if isAdmin() || (request.auth.uid == userId && isActive());
    }

    // Donors & Contributors
    match /donors/{donorId} {
      allow read: if isAdmin() || request.auth.uid == donorId || hasPermission('donors', 'read');
      allow write: if isAdmin() || hasPermission('donors', 'create') || hasPermission('donors', 'update');
    }

    // Donations Ledger
    match /donations/{donationId} {
      allow read: if isAdmin() || 
                   (isSignedIn() && resource.data.donorId == request.auth.uid) || 
                   hasPermission('donations', 'read');
      allow write: if isAdmin() || hasPermission('donations', 'create') || hasPermission('donations', 'update');
    }

    // Master Beneficiary Registry
    match /beneficiaries/{benId} {
      allow read: if isAdmin() || hasPermission('beneficiaries', 'read');
      allow write: if isAdmin() || hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update');
    }

    // Campaigns & Initiative Sub-collections
    match /campaigns/{campId} {
      allow read: if true; // Public initiatives
      allow write: if isAdmin() || hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }

    // Leads & Community Appeals
    match /leads/{leadId} {
      allow read: if true; // Public leads
      allow write: if isAdmin() || hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    // Verification Pipeline (Pending Approvals)
    match /pending_verifications/{requestId} {
      // Members can only see requests specifically assigned to them
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      // Anyone with update perms can request verification
      allow create: if isActive();
      // Only assigned verifiers or Admins can update/delete status
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
    }

    // Analytics (Page Hits)
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true; // Public hit increments
    }
  }
}