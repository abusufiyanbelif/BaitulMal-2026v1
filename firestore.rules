rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Rule Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function hasPermission(module, action) {
      return isAdmin() || (isActive() && getUserData().permissions[module][action] == true);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }
    
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if hasPermission('campaigns', 'read') || resource.data.publicVisibility == 'Published';
      allow create: if hasPermission('campaigns', 'create');
      allow update: if hasPermission('campaigns', 'update');
      allow delete: if hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if hasPermission('campaigns', 'read') || get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published';
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    match /leads/{leadId} {
      allow read: if hasPermission('leads-members', 'read') || resource.data.publicVisibility == 'Published';
      allow create: if hasPermission('leads-members', 'create');
      allow update: if hasPermission('leads-members', 'update');
      allow delete: if hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if hasPermission('leads-members', 'read') || get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published';
        allow write: if hasPermission('leads-members', 'update');
      }
    }

    match /donations/{donationId} {
      allow read: if hasPermission('donations', 'read');
      allow create: if true; // Allow public submissions
      allow update: if hasPermission('donations', 'update');
      allow delete: if hasPermission('donations', 'delete');
    }

    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read') || request.auth.uid == donorId;
      allow write: if hasPermission('donors', 'update') || request.auth.uid == donorId;
    }

    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow create: if hasPermission('beneficiaries', 'create');
      allow update: if hasPermission('beneficiaries', 'update');
      allow delete: if hasPermission('beneficiaries', 'delete');
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pending_verifications/{requestId} {
      // Admins can see everything. 
      // Members can only list documents if they are specifically assigned as verifiers.
      allow read, list: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid in resource.data.assignedVerifierIds)
      );
      allow create: if isActive();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid in resource.data.assignedVerifierIds)
      );
      allow delete: if isAdmin();
    }
    
    match /page_hits/{pageId} {
      allow read: if isAdmin();
      allow write: if true;
    }
  }
}
