rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Get user data from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Is the user an Admin?
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    // Is the user's account Active?
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }

    // Check for a specific permission in the user's profile
    function hasPermission(module, permission) {
      let data = getUserData();
      return isAdmin() || (isActive() && data.permissions[module][permission] == true);
    }

    // --- Collection Rules ---

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    // User Lookups (Used for Login ID/Phone mapping to Email)
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Institutional Settings (Publicly readable for Branding/Payments)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Donors
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'create') || hasPermission('donors', 'update');
      allow delete: if hasPermission('donors', 'delete');
    }

    // Donations
    match /donations/{donationId} {
      allow read: if hasPermission('donations', 'read') || (isSignedIn() && request.auth.uid == resource.data.donorId);
      allow write: if hasPermission('donations', 'create') || hasPermission('donations', 'update');
      allow delete: if hasPermission('donations', 'delete');
    }

    // Beneficiaries (Master List)
    match /beneficiaries/{beneficiaryId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update');
      allow delete: if hasPermission('beneficiaries', 'delete');
    }

    // Campaigns & Initiative-Linked Beneficiaries
    match /campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update');
      allow delete: if hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    // Leads & Case-Linked Beneficiaries
    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update');
      allow delete: if hasPermission('leads-members', 'delete');

      match /beneficiaries/{benId} {
        allow read: if get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
        allow write: if hasPermission('leads-members', 'update');
      }
    }

    // Pending Verifications (Audit Pipeline)
    match /pending_verifications/{requestId} {
      // Admins see everything; Verifiers only see their assignments
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow create: if isActive();
      allow update: if (isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds)) && isActive();
      allow delete: if isAdmin();
    }
    
    // Page Analytics
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}