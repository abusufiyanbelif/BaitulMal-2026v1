rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, permission) {
      return isSignedIn() && (isAdmin() || getUserData().permissions[module][permission] == true);
    }

    // Users: Private profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || hasPermission('users', 'read'));
      allow write: if isAdmin();
    }
    
    // User Lookups: Publicly readable for login
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns: Public if Published & Verified
    match /campaigns/{campaignId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') 
                  || hasPermission('campaigns', 'read');
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if hasPermission('campaigns', 'beneficiaries') || hasPermission('campaigns', 'read');
        allow write: if isAdmin() || hasPermission('campaigns', 'beneficiaries');
      }
    }

    // Leads: Public if Published & Verified
    match /leads/{leadId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') 
                  || hasPermission('leads-members', 'read');
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if hasPermission('leads-members', 'beneficiaries') || hasPermission('leads-members', 'read');
        allow write: if isAdmin() || hasPermission('leads-members', 'beneficiaries');
      }
    }

    // Donations: Publicly list verified totals, full details for members
    match /donations/{donationId} {
      allow read: if resource.data.status == 'Verified' || hasPermission('donations', 'read');
      allow write: if isAdmin() || hasPermission('donations', 'update');
    }

    // Donors: Private registry
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if isAdmin() || hasPermission('donors', 'update');
    }

    // Beneficiaries: Private master list
    match /beneficiaries/{beneficiaryId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    // Settings: Publicly readable branding/info
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Guidance Hub
    match /guidance/{resourceId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('guidance', 'update');
    }
    
    // Page Hits
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}