rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- ADMINISTRATIVE BYPASS ---
    // Primary IDs and specific admin accounts have absolute write access
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'cyMl1lQME0Yur1YS3VCms1AvrOJ2' || 
        request.auth.uid == 'S5efNV5jpTPoxYNv6SnAlv3jNPO2' || 
        request.auth.uid == '3gKwUE2JrBT8wngoUxTTN6tLJk03' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    function isStaff() {
      return request.auth != null && (
        isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'User'
      );
    }

    // --- MODULE PERMISSIONS HELPER ---
    function hasPermission(module, perm) {
      return isAdmin() || (
        isStaff() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[module][perm] == true
      );
    }

    // --- PUBLIC DATA RULES ---
    // Allows public readers to see specific content for landing/public pages
    match /settings/branding { allow read: if true; }
    match /settings/payment { allow read: if true; }
    match /settings/donationInfo { allow read: if true; }
    match /settings/guidingPrinciples { allow read: if true; }
    match /settings/info { allow read: if true; }
    match /settings/guidance { allow read: if true; }
    match /settings/campaign_visibility { allow read: if true; }
    match /settings/lead_visibility { allow read: if true; }
    match /settings/donation_visibility { allow read: if true; }
    match /settings/beneficiary_visibility { allow read: if true; }

    match /donations/{donationId} {
      allow read: if request.auth != null || resource.data.status == 'Verified';
      allow write: if isAdmin() || hasPermission('donations', 'update');
      allow create: if true; // Public gateway support
    }

    match /campaigns/{campaignId} {
      allow read: if true; // Landing page needs access to published names/goals
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isStaff();
      }
    }

    match /leads/{leadId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isStaff();
      }
    }

    match /beneficiaries/{benId} {
      allow read: if request.auth != null;
      allow write: if isStaff();
    }

    match /donors/{donorId} {
      allow read: if request.auth != null && (request.auth.uid == donorId || isStaff());
      allow write: if isAdmin() || hasPermission('donors', 'update');
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isStaff());
      allow write: if isAdmin() || (request.auth.uid == userId);
    }

    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /pending_verifications/{reqId} {
      allow read: if request.auth != null && (
        isAdmin() || 
        userIdInList(request.auth.uid, resource.data.assignedVerifierIds) ||
        request.auth.uid == resource.data.requestedBy.id
      );
      allow write: if request.auth != null;
    }

    match /page_hits/{pageId} {
      allow read: if isStaff();
      allow write: if true;
    }

    function userIdInList(userId, list) {
       return userId in list;
    }
  }
}