rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // SECURITY HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    function hasPermission(module, permission) {
      let permissions = getUserData().permissions;
      return isAdmin() || (isSignedIn() && permissions[module][permission] == true);
    }

    // -------------------------------------------------------------------------
    // COLLECTION RULES
    // -------------------------------------------------------------------------

    // Public Visibility: Branding and Payment details
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public Visibility: Content pages
    match /settings/donationInfo { allow read: if true; }
    match /settings/guidingPrinciples { allow read: if true; }
    match /settings/guidance { allow read: if true; }

    // User Lookups: Public read for sign-in discovery
    match /user_lookups/{identifier} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: Personal access or Admin oversight
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasPermission('users', 'read'));
      allow write: if isSignedIn() && (request.auth.uid == userId || hasPermission('users', 'update'));
      allow create: if hasPermission('users', 'create');
      allow delete: if hasPermission('users', 'delete');
    }

    // Campaigns: Public read if published, otherwise member restricted
    match /campaigns/{campaignId} {
      allow read: if true; // Public oversight
      allow write: if hasPermission('campaigns', 'update');
      allow create: if hasPermission('campaigns', 'create');
      allow delete: if hasPermission('campaigns', 'delete');

      match /beneficiaries/{benId} {
        allow read: if isSignedIn();
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    // Leads: Public read if published
    match /leads/{leadId} {
      allow read: if true;
      allow write: if hasPermission('leads-members', 'update');
      allow create: if hasPermission('leads-members', 'create');
      allow delete: if hasPermission('leads-members', 'delete');

      match /beneficiaries/{benId} {
        allow read: if isSignedIn();
        allow write: if hasPermission('leads-members', 'update');
      }
    }

    // Beneficiaries (Master Registry)
    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'update');
      allow create: if hasPermission('beneficiaries', 'create');
      allow delete: if hasPermission('beneficiaries', 'delete');
    }

    // Donors (Registry)
    match /donors/{donorId} {
      allow read: if isSignedIn() && (request.auth.uid == donorId || hasPermission('donors', 'read'));
      allow write: if isSignedIn() && (request.auth.uid == donorId || hasPermission('donors', 'update'));
      allow create: if hasPermission('donors', 'create');
      allow delete: if hasPermission('donors', 'delete');
    }

    // Donations
    match /donations/{donationId} {
      allow read: if isSignedIn() && (request.resource.data.donorId == request.auth.uid || hasPermission('donations', 'read'));
      allow write: if hasPermission('donations', 'update');
      allow create: if isSignedIn(); // Allow public gateway or members to create
      allow delete: if hasPermission('donations', 'delete');
    }

    // Verification Pipeline (The Approval Workflow)
    match /pending_verifications/{requestId} {
      // Rule for 'list' and 'get'
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      // Rule for creation
      allow create: if isSignedIn();
      // Rule for updates (approvals/rejections)
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      // Rule for removal (cleanup)
      allow delete: if isAdmin();
    }

    // Analytics & Logs
    match /page_hits/{pageId} {
      allow read: if hasPermission('analytics', 'read');
      allow write: if true; // Increment hits
    }
  }
}