/**
 * DocuExtract Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset enforces a strict hierarchical ownership model. All application data 
 * (documents, extractions, and profiles) is nested under a specific user's path, 
 * leveraging path-based authorization to ensure that users can only access their own data.
 *
 * Data Structure:
 * - /users/{userId}: Root user profile.
 * - /users/{userId}/documents/{documentId}: Documents uploaded by the user.
 * - /users/{userId}/documents/{documentId}/[extraction_type]/{extractionId}: 
 *   Specialized subcollections for structured data extracted from documents.
 *
 * Key Security Decisions:
 * 1. Path-Based Authorization: We use the {userId} parameter in the document path 
 *    as the primary source of truth for ownership. This is performant and avoids 
 *    unnecessary get() calls.
 * 2. Strict User Segregation: Users cannot list other users or access documents/extractions 
 *    outside of their own tree.
 * 3. Relational Integrity: While in Prototyping Mode, we do not enforce strict schema 
 *    types, but we do enforce that critical relational fields (like userId or documentId) 
 *    match the path and remain immutable after creation.
 * 4. Default Deny: All access is denied by default unless explicitly permitted by an 
 *    ownership check.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner and the document exists (for updates/deletes).
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile collection.
     * @path /users/{userId}
     * @allow (get) if the user is accessing their own profile.
     * @deny (list) to prevent user enumeration.
     * @principle Pattern 4: Self-Creation and Ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for Documents uploaded by a user.
       * @path /users/{userId}/documents/{documentId}
       * @allow (create) if the ownerId in data matches the path userId.
       * @deny (update) if the ownerId is modified.
       * @principle Pattern 1: Ownership via nested path.
       */
      match /documents/{documentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.id == documentId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for Identity Proof Extractions.
         * @path /users/{userId}/documents/{documentId}/identityProofExtractions/{extractionId}
         * @allow (get) if the user owns the parent document tree.
         * @deny (create) if documentId in data doesn't match path documentId.
         * @principle Relational integrity and inherited ownership.
         */
        match /identityProofExtractions/{extractionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId) && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for Billing Extractions.
         * @path /users/{userId}/documents/{documentId}/billingExtractions/{extractionId}
         * @allow (list) by the owner of the document tree.
         * @principle Inherited path ownership.
         */
        match /billingExtractions/{extractionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId) && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for Medical Report Extractions.
         * @path /users/{userId}/documents/{documentId}/medicalReportExtractions/{extractionId}
         * @allow (update) if ownership is maintained and doc exists.
         * @principle Robustness for state-changing operations.
         */
        match /medicalReportExtractions/{extractionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId) && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}