rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- ADMINISTRATIVE HELPERS ---
    
    // Hardcoded Superuser Bypasses (for Abusufiyan, Maaz, and System Admin)
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == "abusufiyan.belif@gmail.com" ||
        request.auth.token.email == "maazshaikh.official@gmail.com" ||
        request.auth.token.email == "baitulmalss.solapur@gmail.com" ||
        request.auth.token.email == "admin@example.com" ||
        request.auth.uid == "cyMl1lQME0Yur1YS3VCms1AvrOJ2" ||
        request.auth.uid == "S5efNV5jpTPoxYNv6SnAlv3jNPO2" ||
        request.auth.uid == "3gKwUE2JrBT8wngoUxTTN6tLJk03"
      );
    }

    // Role Based Access Control (RBAC) via User Profile
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && (isSuperAdmin() || getUserRole() == "Admin");
    }
    
    function isMember() {
      return request.auth != null && (isAdmin() || getUserRole() == "User");
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /donors/{donorId} {
      allow read: if request.auth != null;
      allow write: if isMember();
    }

    match /donations/{donationId} {
      allow read: if request.auth != null;
      allow write: if isMember();
    }

    match /beneficiaries/{beneficiaryId} {
      allow read: if request.auth != null;
      allow write: if isMember();
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isMember();
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isMember();
      }
    }

    match /leads/{leadId} {
      allow read: if true;
      allow write: if isMember();
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isMember();
      }
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pending_verifications/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isMember();
    }

    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
