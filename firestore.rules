rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        getUserData().role == 'Admin' || 
        request.auth.token.email == 'baitulmalss.solapur@gmail.com' ||
        request.auth.token.email == 'abusufiyan.belif@gmail.com' ||
        request.auth.token.email == 'maazshaikh.official@gmail.com' ||
        request.auth.token.email == 'admin@example.com'
      );
    }

    function hasPermission(module, action) {
      return isAdmin() || (isSignedIn() && getUserData().permissions[module][action] == true);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /user_lookups/{lookupId} {
      allow read: if true; // Publicly readable for sign-in logic
      allow write: if isAdmin();
    }

    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read') || request.auth.uid == donorId;
      allow write: if hasPermission('donors', 'update') || isAdmin();
    }

    match /donations/{donationId} {
      allow read: if hasPermission('donations', 'read') || request.resource.data.donorId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if hasPermission('donations', 'update') || isAdmin();
    }

    match /beneficiaries/{beneficiaryId} {
      allow read: if hasPermission('beneficiaries', 'read') || request.auth.uid == beneficiaryId;
      allow write: if hasPermission('beneficiaries', 'update') || isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if true; // Publicly readable
      allow write: if hasPermission('campaigns', 'update') || isAdmin();
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if hasPermission('campaigns', 'update') || isAdmin();
      }
    }

    match /leads/{leadId} {
      allow read: if true; // Publicly readable
      allow write: if hasPermission('leads-members', 'update') || isAdmin();
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if hasPermission('leads-members', 'update') || isAdmin();
      }
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pending_verifications/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }

    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}