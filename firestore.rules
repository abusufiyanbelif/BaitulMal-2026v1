rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Simplified Institutional Rules
    // 1. Public Transparency: Anyone can read verified data and published content.
    // 2. Member Control: Any authenticated member can manage data.
    
    match /{document=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
  }
}