rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user document from registry
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Institutional Role Checks
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }

    // Helper: Granular Module Permissions
    function hasPermission(module, action) {
      return getUserData().permissions[module][action] == true;
    }

    // Admins have global superuser access to all collections and files
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Public Institutional Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Identity Lookup Registry (Public read for login discovery)
    match /user_lookups/{lookupId} {
      allow read: if true;
    }

    // User Registry: Owner access or Admin oversight
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId || isAdmin();
    }

    // Verification Pipeline: Assigned verifiers or Admins
    match /pending_verifications/{requestId} {
      allow get: if isSignedIn() && (request.auth.uid in resource.data.assignedVerifierIds || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid in resource.data.assignedVerifierIds || isAdmin());
      allow create: if isSignedIn() && isActive();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.assignedVerifierIds || isAdmin());
      allow delete: if isAdmin();
    }

    // Registries: Governed by Active Staff Permissions
    match /donors/{donorId} {
      allow read: if isAdmin() || hasPermission('donors', 'read');
      allow create: if isAdmin() || hasPermission('donors', 'create');
      allow update: if isAdmin() || hasPermission('donors', 'update');
      allow delete: if isAdmin() || hasPermission('donors', 'delete');
    }

    match /donations/{donationId} {
      allow read: if isAdmin() || hasPermission('donations', 'read');
      allow create: if isAdmin() || hasPermission('donations', 'create');
      allow update: if isAdmin() || hasPermission('donations', 'update');
      allow delete: if isAdmin() || hasPermission('donations', 'delete');
    }

    match /beneficiaries/{benId} {
      allow read: if isAdmin() || hasPermission('beneficiaries', 'read');
      allow create: if isAdmin() || hasPermission('beneficiaries', 'create');
      allow update: if isAdmin() || hasPermission('beneficiaries', 'update');
      allow delete: if isAdmin() || hasPermission('beneficiaries', 'delete');
    }

    // Initiatives: Publicly readable when Published
    match /campaigns/{campId} {
      allow read: if resource.data.publicVisibility == 'Published' || isAdmin() || hasPermission('campaigns', 'read');
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if get(/databases/$(database)/documents/campaigns/$(campId)).data.publicVisibility == 'Published' || isAdmin() || hasPermission('campaigns', 'read');
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }

    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || isAdmin() || hasPermission('leads-members', 'read');
      allow write: if isAdmin() || hasPermission('leads-members', 'update');

      match /beneficiaries/{benId} {
        allow read: if get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || isAdmin() || hasPermission('leads-members', 'read');
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }
  }
}