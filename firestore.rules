rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    // Check if user is a hardcoded Super Admin or has the Admin role
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid in [
          'S5efNV5jpTPoxYNv6SnAlv3jNPO2', // Abusufiyan Belif
          'cyMl1lQME0Yur1YS3VCms1AvrOJ2', // BaitulMal System Admin
          '3gKwUE2JrBT8wngoUxTTN6tLJk03'  // Maaz A. Rauf Shaikh
        ] || 
        request.auth.token.email in [
          'abusufiyan.belif@gmail.com',
          'baitulmalss.solapur@gmail.com',
          'maazshaikh.official@gmail.com',
          'admin@example.com'
        ] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    // Check granular module permissions
    function hasPermission(module, action) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userDoc.role == 'Admin' || (
        userDoc.permissions != null && 
        userDoc.permissions[module] != null && 
        userDoc.permissions[module][action] == true
      );
    }

    // --- COLLECTION RULES ---

    // Settings are public for branding but admin-only for writes
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns & Leads: Public read if Published, otherwise role-based
    match /campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == 'Published' || isAdmin() || hasPermission('campaigns', 'read');
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if isAdmin() || hasPermission('campaigns', 'read');
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }
    
    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || isAdmin() || hasPermission('leads-members', 'read');
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if isAdmin() || hasPermission('leads-members', 'read');
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    // Donations: Public read for Verified (progress tracking), role-based otherwise
    match /donations/{donationId} {
      allow read: if resource.data.status == 'Verified' || isAdmin() || hasPermission('donations', 'read');
      allow write: if isAdmin() || hasPermission('donations', 'update');
    }

    // Master Beneficiary Registry: Private
    match /beneficiaries/{benId} {
      allow read: if isAdmin() || hasPermission('beneficiaries', 'read');
      allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    // Donors: Private
    match /donors/{donorId} {
      allow read: if isAdmin() || hasPermission('donors', 'read');
      allow write: if isAdmin() || hasPermission('donors', 'update');
    }

    // Users: Owner or Admin
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || hasPermission('users', 'read'));
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // User Lookups: Public (for login discovery)
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Verification Pipeline: Open to members to request/audit
    match /pending_verifications/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // Analytics hits
    match /page_hits/{id} {
      allow read, write: if true;
    }
  }
}