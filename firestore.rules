rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- ADMINISTRATIVE BYPASS ---
    // Specifically identifying the three primary identities for absolute oversight.
    function isSystemAdmin() {
      return request.auth != null && (
        request.auth.uid == "cyMl1lQME0Yur1YS3VCms1AvrOJ2" || // System Admin
        request.auth.uid == "S5efNV5jpTPoxYNv6SnAlv3jNPO2" || // Abusufiyan Belif
        request.auth.uid == "3gKwUE2JrBT8wngoUxTTN6tLJk03" || // Maaz A. Rauf Shaikh
        request.auth.token.email == "baitulmalss.solapur@gmail.com" ||
        request.auth.token.email == "abusufiyan.belif@gmail.com"
      );
    }

    // --- GLOBAL RULE FOR TESTING PHASE ---
    // Per your request, we allow all authenticated users full access.
    // The UI-level role checks will manage the professional dashboard presentation.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow listing for the verification pipeline to resolve the reported error.
    match /pending_verifications/{request} {
      allow list, get: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /user_lookups/{identifier} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}