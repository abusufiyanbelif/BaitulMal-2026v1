
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function userExists() {
      return exists(userDoc(request.auth.uid));
    }

    function getUserData() {
        return get(userDoc(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             userExists() &&
             getUserData().get('role', 'User').lower() == 'admin';
    }

    function hasPermission(module, permission) {
        return isSignedIn() && 
               userExists() &&
               (
                 isAdmin() ||
                 (
                   'permissions' in getUserData() &&
                   module in getUserData().permissions &&
                   getUserData().permissions[module].get(permission, false) == true
                 )
               );
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('settings', 'update');
    }
    
    match /page_hits/{pageId} {
        allow read: if hasPermission('analytics', 'read') || isAdmin();
        allow write: if true; 
    }

    match /user_lookups/{lookupId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'create'));
      allow update: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'delete'));

      match /beneficiaries/{beneficiaryId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /donations/{donationId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }
    
    match /leads/{leadId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'create'));
      allow update: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'delete'));

       match /beneficiaries/{beneficiaryId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /donations/{donationId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }
    
    match /donations/{donationId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /beneficiaries/{beneficiaryId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'create'));
      allow update: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'delete'));
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || hasPermission('users', 'read') || isAdmin();
      allow list: if hasPermission('users', 'read') || hasPermission('settings', 'update') || isAdmin();
      allow create: if isOwner(userId) || hasPermission('users', 'create') || isAdmin();
      allow update: if isOwner(userId) || hasPermission('users', 'update') || isAdmin();
      allow delete: if (request.auth.uid != userId && hasPermission('users', 'delete')) || (isAdmin() && request.auth.uid != userId);
    }
  }
}
