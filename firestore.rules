
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function hasPermission(module, permission) {
        return isSignedIn() && getUserData().permissions[module][permission] == true;
    }

    function hasSubmodulePermission(module, submodule, permission) {
        return isSignedIn() && getUserData().permissions[module][submodule][permission] == true;
    }

    function isUserProfileDataConsistent(userId) {
      return request.resource.data.id == userId;
    }

    function isUserProfileIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    function isDocumentDataConsistent(userId) {
      return request.resource.data.userId == userId;
    }

    function isDocumentUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    function isExtractionDataConsistent(documentId) {
      return request.resource.data.documentId == documentId;
    }

    function isExtractionDocIdImmutable() {
      return request.resource.data.documentId == resource.data.documentId;
    }

    function isLineItemDataConsistent(billingExtractionId) {
      return request.resource.data.billingExtractionId == billingExtractionId;
    }

    function isLineItemExtractionIdImmutable() {
      return request.resource.data.billingExtractionId == resource.data.billingExtractionId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('settings', 'update');
    }

    match /user_lookups/{lookupId} {
        allow read: if true;
        allow write: if true;
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'create'));
      allow update: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'delete'));

      match /beneficiaries/{beneficiaryId} {
        allow read: if true;
        allow create: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'beneficiaries', 'create'));
        allow update: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'beneficiaries', 'update'));
        allow delete: if isSignedIn() && (isAdmin() || hasSubmodulePermission('campaigns', 'beneficiaries', 'delete'));
      }
    }
    
    match /leads/{leadId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'create'));
      allow update: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'update'));
      allow delete: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'delete'));

       match /beneficiaries/{beneficiaryId} {
        allow read: if true;
        allow create: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'beneficiaries', 'create'));
        allow update: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'beneficiaries', 'update'));
        allow delete: if isSignedIn() && (isAdmin() || hasSubmodulePermission('leads-members', 'beneficiaries', 'delete'));
      }
    }
    
    match /donations/{donationId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(request.resource.data.uploadedById) || hasPermission('donations', 'update') || isAdmin());
      allow delete: if isSignedIn() && (isOwner(resource.data.uploadedById) || hasPermission('donations', 'delete') || isAdmin());
    }
    
    match /beneficiaries/{beneficiaryId} {
      allow read: if true;
      allow create: if isSignedIn() && (hasPermission('beneficiaries', 'create') || isAdmin());
      allow update: if isSignedIn() && (hasPermission('beneficiaries', 'update') || isAdmin());
      allow delete: if isSignedIn() && (hasPermission('beneficiaries', 'delete') || isAdmin());
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || hasPermission('users', 'read') || isAdmin();
      allow list: if hasPermission('users', 'read') || isAdmin();
      allow create: if (isOwner(userId) && isUserProfileDataConsistent(userId)) || hasPermission('users', 'create') || isAdmin();
      allow update: if (isOwner(userId) && isUserProfileIdImmutable()) || hasPermission('users', 'update') || isAdmin();
      allow delete: if (request.auth.uid != userId && hasPermission('users', 'delete')) || (isAdmin() && request.auth.uid != userId);

      match /documents/{documentId} {
        allow read: if true;
        allow create: if (isOwner(userId) && isDocumentDataConsistent(userId)) || isAdmin();
        allow update: if (isOwner(userId) && isDocumentUserIdImmutable()) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();

        match /identityProofExtractions/{extractionId} {
          allow read: if true;
          allow create: if (isOwner(userId) && isExtractionDataConsistent(documentId)) || isAdmin();
          allow update: if (isOwner(userId) && isExtractionDocIdImmutable()) || isAdmin();
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /billingExtractions/{extractionId} {
          allow read: if true;
          allow create: if (isOwner(userId) && isExtractionDataConsistent(documentId)) || isAdmin();
          allow update: if (isOwner(userId) && isExtractionDocIdImmutable()) || isAdmin();
          allow delete: if isOwner(userId) || isAdmin();

          match /lineItems/{lineItemId} {
            allow read: if true;
            allow create: if (isOwner(userId) && isLineItemDataConsistent(extractionId)) || isAdmin();
            allow update: if (isOwner(userId) && isLineItemExtractionIdImmutable()) || isAdmin();
            allow delete: if isOwner(userId) || isAdmin();
          }
        }

        match /medicalReportExtractions/{extractionId} {
          allow read: if true;
          allow create: if (isOwner(userId) && isExtractionDataConsistent(documentId)) || isAdmin();
          allow update: if (isOwner(userId) && isExtractionDocIdImmutable()) || isAdmin();
          allow delete: if isOwner(userId) || isAdmin();
        }
      }
    }
  }
}
