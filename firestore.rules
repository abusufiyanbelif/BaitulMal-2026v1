rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Core Administrative Bypass
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in [
          'abusufiyan.belif@gmail.com', 
          'baitulmalss.solapur@gmail.com', 
          'maazshaikh.official@gmail.com',
          'admin@example.com'
        ] || 
        request.auth.uid in [
          'cyMl1lQME0Yur1YS3VCms1AvrOJ2', 
          'S5efNV5jpTPoxYNv6SnAlv3jNPO2', 
          '3gKwUE2JrBT8wngoUxTTN6tLJk03'
        ] ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    // 2. Resource-Specific Rules
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null);
      
      match /beneficiaries/{beneficiaryId} {
        allow read, write: if request.auth != null;
      }
    }

    match /leads/{leadId} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null);
      
      match /beneficiaries/{beneficiaryId} {
        allow read, write: if request.auth != null;
      }
    }

    match /donations/{donationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /beneficiaries/{beneficiaryId} {
      allow read, write: if request.auth != null;
    }

    match /donors/{donorId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /user_lookups/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pending_verifications/{id} {
      allow read, write: if request.auth != null;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null);
    }
  }
}