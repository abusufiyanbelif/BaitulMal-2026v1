rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, action) {
      return isAdmin() || (isSignedIn() && getUserData().permissions[module][action] == true);
    }

    // Public Institutional Settings
    match /settings/branding {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/payment {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/donationInfo {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/guidingPrinciples {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/guidance {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{any} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // User and Lookups
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Main Collections
    match /campaigns/{campaignId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') || isSignedIn();
      allow write: if hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if isSignedIn();
        allow write: if hasPermission('campaigns', 'update');
      }
    }
    
    match /leads/{leadId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') || isSignedIn();
      allow write: if hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if isSignedIn();
        allow write: if hasPermission('leads-members', 'update');
      }
    }

    match /donations/{donationId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('donations', 'update');
    }

    match /beneficiaries/{benId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('beneficiaries', 'update');
    }

    match /donors/{donorId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('donors', 'update');
    }
    
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}