rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function hasPermission(module, permission) {
      return isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[module][permission] == true);
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true; // Branding and public settings are readable by everyone
      allow write: if isAdmin();
    }

    // User Profiles & Lookups
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
    match /user_lookups/{lookupId} {
      allow read: if true; // Publicly readable for custom login
      allow write: if isAdmin();
    }

    // Campaigns
    match /campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
      allow create: if hasPermission('campaigns', 'create');
      allow update: if hasPermission('campaigns', 'update') || hasPermission('campaigns.summary', 'update') || hasPermission('campaigns.ration', 'update');
      allow delete: if hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{beneficiaryId} {
        // Allow guest visitors to list beneficiaries for the breakdown table if the campaign is published
        allow list: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || hasPermission('campaigns.beneficiaries', 'read');
        allow get: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || hasPermission('campaigns.beneficiaries', 'read');
        allow write: if hasPermission('campaigns.beneficiaries', 'update');
      }
    }

    // Leads
    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
      allow create: if hasPermission('leads-members', 'create');
      allow update: if hasPermission('leads-members', 'update') || hasPermission('leads-members.summary', 'update');
      allow delete: if hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{beneficiaryId} {
        allow list: if get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || hasPermission('leads-members.beneficiaries', 'read');
        allow get: if get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || hasPermission('leads-members.beneficiaries', 'read');
        allow write: if hasPermission('leads-members.beneficiaries', 'update');
      }
    }

    // Beneficiaries (Master List)
    match /beneficiaries/{beneficiaryId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'update');
    }

    // Donors
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'update');
    }

    // Donations
    match /donations/{donationId} {
      // Verified donations are readable by everyone to compute progress metrics
      allow read: if resource.data.status == 'Verified' || hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'update');
    }
    
    // Page Hits
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}