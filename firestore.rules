rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, action) {
      return isAdmin() || (isSignedIn() && getUserData().permissions[module][action] == true);
    }

    // Public access to branding and app settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public access to verified initiatives
    match /campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || hasPermission('campaigns', 'beneficiaries.read');
        allow write: if hasPermission('campaigns', 'beneficiaries.update');
      }
    }

    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || hasPermission('leads-members', 'beneficiaries.read');
        allow write: if hasPermission('leads-members', 'beneficiaries.update');
      }
    }

    // Public access to verified donations for metrics
    match /donations/{donationId} {
      allow read: if resource.data.status == 'Verified' || hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'create');
    }

    // Master lists - Strictly Protected
    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'create');
    }
    
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'create');
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (request.auth.uid == userId);
    }
    
    match /user_lookups/{lookupId} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}