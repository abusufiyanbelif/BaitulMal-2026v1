rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is an Admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Helper to check for specific module permissions
    function hasPermission(module, permission) {
      return request.auth != null && (
        isAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[module][permission] == true
      );
    }

    // Pending Verifications
    match /pending_verifications/{requestId} {
      allow create: if request.auth != null;
      // Allow list if Admin or if explicitly assigned to the user
      allow list: if request.auth != null && (
        isAdmin() || 
        request.auth.uid in resource.data.assignedVerifierIds
      );
      allow get: if request.auth != null && (
        isAdmin() || 
        request.auth.uid in resource.data.assignedVerifierIds || 
        request.auth.uid == resource.data.requestedBy.id
      );
      allow update: if request.auth != null && (
        isAdmin() || 
        request.auth.uid in resource.data.assignedVerifierIds
      );
      allow delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || hasPermission('users', 'read'));
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // User Lookups (Publicly readable for login)
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Donations
    match /donations/{id} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('donations', 'read'));
      allow write: if request.auth != null && (isAdmin() || hasPermission('donations', 'create') || hasPermission('donations', 'update'));
    }

    // Donors
    match /donors/{id} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('donors', 'read'));
      allow write: if request.auth != null && (isAdmin() || hasPermission('donors', 'create') || hasPermission('donors', 'update'));
    }

    // Campaigns
    match /campaigns/{id} {
      allow read: if true; // Public view
      allow write: if request.auth != null && (isAdmin() || hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update'));
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if request.auth != null && (isAdmin() || hasPermission('campaigns', 'update'));
      }
    }

    // Leads
    match /leads/{id} {
      allow read: if true; // Public view
      allow write: if request.auth != null && (isAdmin() || hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update'));
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if request.auth != null && (isAdmin() || hasPermission('leads-members', 'update'));
      }
    }

    // Beneficiaries (Master)
    match /beneficiaries/{id} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('beneficiaries', 'read'));
      allow write: if request.auth != null && (isAdmin() || hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update'));
    }

    // Settings
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Page Hits
    match /page_hits/{id} {
      allow read, write: if true;
    }
  }
}