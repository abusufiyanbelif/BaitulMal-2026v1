rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().get('role', '') == 'Admin';
    }

    // Defensive permission checker that handles missing fields and legacy formats safely
    function hasPermission(module, action) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               getUserData().get('role', '') == 'Admin' ||
               getUserData().get('permissions', {}).get(module, {}).get(action, false) == true ||
               getUserData().get('permissions', {}).get(module, {}).get(action == 'update' ? 'canEdit' : action == 'create' ? 'canAdd' : action == 'delete' ? 'canDelete' : action, false) == true
             );
    }
    
    function hasSubPermission(module, submodule, action) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               getUserData().get('role', '') == 'Admin' ||
               getUserData().get('permissions', {}).get(module, {}).get(submodule, {}).get(action, false) == true ||
               getUserData().get('permissions', {}).get(module, {}).get(submodule, {}).get(action == 'update' ? 'canEdit' : action == 'create' ? 'canAdd' : action == 'delete' ? 'canDelete' : action, false) == true
             );
    }

    function canCreate(module) { return hasPermission(module, 'create'); }
    function canUpdate(module) { return hasPermission(module, 'update'); }
    function canDelete(module) { return hasPermission(module, 'delete'); }
    
    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create: if canCreate('campaigns');
      allow update: if canUpdate('campaigns') || hasSubPermission('campaigns', 'ration', 'update') || hasSubPermission('campaigns', 'beneficiaries', 'update') || hasSubPermission('campaigns', 'summary', 'update');
      allow delete: if canDelete('campaigns');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if true;
        allow create: if canCreate('campaigns') || hasSubPermission('campaigns', 'beneficiaries', 'create');
        allow update: if canUpdate('campaigns') || hasSubPermission('campaigns', 'beneficiaries', 'update') || hasSubPermission('campaigns', 'ration', 'update');
        allow delete: if canDelete('campaigns') || hasSubPermission('campaigns', 'beneficiaries', 'delete');
      }
    }

    match /leads/{leadId} {
      allow read: if true;
      allow create: if canCreate('leads-members') || canCreate('leads');
      allow update: if canUpdate('leads-members') || canUpdate('leads') || hasSubPermission('leads-members', 'beneficiaries', 'update') || hasSubPermission('leads', 'beneficiaries', 'update');
      allow delete: if canDelete('leads-members') || canDelete('leads');
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if true;
        allow create: if canCreate('leads-members') || canCreate('leads') || hasSubPermission('leads-members', 'beneficiaries', 'create') || hasSubPermission('leads', 'beneficiaries', 'create');
        allow update: if canUpdate('leads-members') || canUpdate('leads') || hasSubPermission('leads-members', 'beneficiaries', 'update') || hasSubPermission('leads', 'beneficiaries', 'update');
        allow delete: if canDelete('leads-members') || canDelete('leads') || hasSubPermission('leads-members', 'beneficiaries', 'delete') || hasSubPermission('leads', 'beneficiaries', 'delete');
      }
    }

    match /beneficiaries/{beneficiaryId} {
      allow read: if true;
      allow create: if canCreate('beneficiaries');
      allow update: if canUpdate('beneficiaries');
      allow delete: if canDelete('beneficiaries');
    }

    match /donations/{donationId} {
      allow read: if true;
      allow create: if canCreate('donations');
      allow update: if canUpdate('donations');
      allow delete: if canDelete('donations');
    }

    match /donors/{donorId} {
      allow read: if true;
      allow create: if canCreate('donors');
      allow update: if canUpdate('donors');
      allow delete: if canDelete('donors');
    }

    match /settings/{docId} {
      allow read: if true;
      allow create: if canCreate('settings');
      allow update: if canUpdate('settings');
      allow delete: if canDelete('settings');
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isUserAdmin() || canUpdate('users') || canCreate('users');
      allow list: if isUserAdmin() || canUpdate('users') || canCreate('users');
      allow create: if isOwner(userId) || canCreate('users');
      allow update: if isOwner(userId) || canUpdate('users');
      allow delete: if canDelete('users');
      
      match /documents/{documentId} {
        allow read: if isOwner(userId) || isUserAdmin() || canUpdate('users');
        allow create: if isOwner(userId) || canCreate('users');
        allow update: if isOwner(userId) || canUpdate('users');
        allow delete: if isOwner(userId) || canDelete('users');
        
        match /{documentDetailsType}/{detailId} {
           allow read, write: if isOwner(userId) || isUserAdmin() || canUpdate('users');
        }
      }
    }

    match /pending_verifications/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isUserAdmin() || canDelete('donations') || canDelete('campaigns') || canDelete('leads-members') || canDelete('beneficiaries') || canDelete('users');
    }
    
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow create, update, delete: if isUserAdmin() || canCreate('users') || canUpdate('users');
    }
  }
}