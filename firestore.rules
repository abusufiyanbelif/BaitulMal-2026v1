rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'; }
    function hasPermission(mod, action) { 
      let permissions = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions;
      return isAdmin() || (permissions != null && permissions[mod] != null && permissions[mod][action] == true);
    }

    // Settings are public for branding and info
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns: Public if Published
    match /campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == 'Published' || isSignedIn();
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || isSignedIn();
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
      match /donations/{donId} {
        allow read: if isSignedIn(); // Sensitive linking info
        allow write: if isAdmin();
      }
    }

    // Leads: Public if Published
    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || isSignedIn();
      allow write: if isAdmin() || hasPermission('leads-members', 'update');

      match /beneficiaries/{benId} {
        allow read: if get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || isSignedIn();
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    // Donations: Public verification status for progress tracking
    match /donations/{donationId} {
      allow read: if resource.data.status == 'Verified' || isSignedIn();
      allow write: if isAdmin() || hasPermission('donations', 'create');
    }

    // Sensitive Master Lists: Strictly Authenticated
    match /beneficiaries/{benId} {
      allow read, write: if isSignedIn();
    }
    match /donors/{donorId} {
      allow read, write: if isSignedIn();
    }
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (request.auth.uid == userId);
    }
    match /user_lookups/{id} {
      allow read: if true; // Required for Login ID lookup during sign-in
      allow write: if isAdmin();
    }
    
    // Analytics & Logs
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}