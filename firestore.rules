rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if a user is an admin via role or sovereign identity
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
        request.auth.token.email in ['abusufiyan.belif@gmail.com', 'baitulmalss.solapur@gmail.com', 'maazshaikh.official@gmail.com', 'admin@example.com'] ||
        request.auth.uid in ['cyMl1lQME0Yur1YS3VCms1AvrOJ2', 'S5efNV5jpTPoxYNv6SnAlv3jNPO2', '3gKwUE2JrBT8wngoUxTTN6tLJk03']
      );
    }

    // Helper to check for specific module permissions
    function hasPermission(module, action) {
      let permissions = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions;
      return isAdmin() || (permissions != null && permissions[module][action] == true);
    }

    // Administrative override: Admins have full access to everything
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Pending Verifications - Always accessible for authenticated members to facilitate pipeline
    match /pending_verifications/{id} {
      allow read, write: if request.auth != null;
    }

    // Public institutional settings
    match /settings/branding { allow read: if true; }
    match /settings/payment { allow read: if true; }
    match /settings/info { allow read: if true; }
    match /settings/guidance { allow read: if true; }
    match /settings/donationInfo { allow read: if true; }
    match /settings/guidingPrinciples { allow read: if true; }

    // User profile management
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, delete: if isAdmin();
    }

    // User lookups are public to allow login resolution
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns & Leads (Publicly readable, protected writes)
    match /campaigns/{id} {
      allow read: if true;
      allow write: if hasPermission('campaigns', 'update');
    }
    match /campaigns/{id}/beneficiaries/{bId} {
      allow read: if true;
      allow write: if hasPermission('campaigns', 'update');
    }

    match /leads/{id} {
      allow read: if true;
      allow write: if hasPermission('leads-members', 'update');
    }
    match /leads/{id}/beneficiaries/{bId} {
      allow read: if true;
      allow write: if hasPermission('leads-members', 'update');
    }

    // Donations & Donors
    match /donations/{id} {
      allow read: if hasPermission('donations', 'read') || request.auth.uid == resource.data.donorId;
      allow write: if hasPermission('donations', 'update');
    }
    match /donors/{id} {
      allow read: if hasPermission('donors', 'read') || request.auth.uid == id;
      allow write: if hasPermission('donors', 'update');
    }
    
    // Page hits for impact analytics
    match /page_hits/{id} {
      allow read, write: if true;
    }
  }
}