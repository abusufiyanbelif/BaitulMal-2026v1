rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function isAdmin() {
      return isActive() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, perm) {
      return isAdmin() || (isActive() && getUserData().permissions[module][perm] == true);
    }

    // Collection Rules
    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.auth.uid == userId; 
    }
    
    match /user_lookups/{id} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    
    match /pending_verifications/{id} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds || request.auth.uid == resource.data.requestedBy.id);
      allow create: if isActive();
      allow update: if isActive() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin() || (isActive() && request.auth.uid == resource.data.requestedBy.id);
    }
    
    match /donations/{id} {
      allow read: if hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'create');
      allow update: if hasPermission('donations', 'update');
      allow delete: if hasPermission('donations', 'delete');
    }
    
    match /donors/{id} {
      allow read: if hasPermission('donors', 'read') || (isSignedIn() && request.auth.uid == id);
      allow write: if hasPermission('donors', 'create');
      allow update: if hasPermission('donors', 'update') || (isSignedIn() && request.auth.uid == id);
      allow delete: if hasPermission('donors', 'delete');
    }
    
    match /beneficiaries/{id} {
      allow read: if hasPermission('beneficiaries', 'read') || (isSignedIn() && request.auth.uid == id);
      allow write: if hasPermission('beneficiaries', 'create');
      allow update: if hasPermission('beneficiaries', 'update') || (isSignedIn() && request.auth.uid == id);
      allow delete: if hasPermission('beneficiaries', 'delete');
    }
    
    match /campaigns/{id} {
      allow read: if hasPermission('campaigns', 'read') || resource.data.publicVisibility == 'Published';
      allow write: if hasPermission('campaigns', 'create');
      allow update: if hasPermission('campaigns', 'update');
      allow delete: if hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if hasPermission('campaigns', 'read');
        allow write: if hasPermission('campaigns', 'update');
      }
    }
    
    match /leads/{id} {
      allow read: if hasPermission('leads-members', 'read') || resource.data.publicVisibility == 'Published';
      allow write: if hasPermission('leads-members', 'create');
      allow update: if hasPermission('leads-members', 'update');
      allow delete: if hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if hasPermission('leads-members', 'read');
        allow write: if hasPermission('leads-members', 'update');
      }
    }
    
    match /settings/{id} {
      allow read: if true; 
      allow write: if isAdmin();
    }
    
    match /page_hits/{id} {
      allow read, write: if true; 
    }
  }
}