rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is the user a signed-in Admin?
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return request.auth != null && (
        (userDoc != null && userDoc.data.role == "Admin") ||
        request.auth.token.email in ["abusufiyan.belif@gmail.com", "baitulmalss.solapur@gmail.com", "maazshaikh.official@gmail.com", "admin@example.com"] ||
        request.auth.uid in ["cyMl1lQME0Yur1YS3VCms1AvrOJ2", "S5efNV5jpTPoxYNv6SnAlv3jNPO2", "3gKwUE2JrBT8wngoUxTTN6tLJk03"]
      );
    }

    // Helper: Does the user have a specific module permission?
    function hasPermission(module, action) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null && (
        isAdmin() || 
        (user.permissions != null && user.permissions[module] != null && user.permissions[module][action] == true)
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /donors/{donorId} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('donors', 'read') || request.auth.uid == donorId);
      allow write: if request.auth != null && (isAdmin() || hasPermission('donors', 'update') || request.auth.uid == donorId);
    }

    match /donations/{donationId} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('donations', 'read') || (resource != null && resource.data.donorId == request.auth.uid));
      allow write: if request.auth != null && (isAdmin() || hasPermission('donations', 'update'));
      allow create: if request.auth != null;
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if request.auth != null && (isAdmin() || hasPermission('campaigns', 'update'));
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if request.auth != null && (isAdmin() || hasPermission('campaigns', 'update'));
      }
    }

    match /leads/{leadId} {
      allow read: if true;
      allow write: if request.auth != null && (isAdmin() || hasPermission('leads-members', 'update'));
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if request.auth != null && (isAdmin() || hasPermission('leads-members', 'update'));
      }
    }

    match /beneficiaries/{benId} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('beneficiaries', 'read'));
      allow write: if request.auth != null && (isAdmin() || hasPermission('beneficiaries', 'update'));
    }

    match /pending_verifications/{requestId} {
      // FIX: Explicitly allow listing for admins or assigned verifiers
      allow list: if request.auth != null && (
        isAdmin() || 
        (resource != null && request.auth.uid in resource.data.assignedVerifierIds)
      );
      allow get: if request.auth != null && (
        isAdmin() || 
        (resource != null && (request.auth.uid in resource.data.assignedVerifierIds || resource.data.requestedBy.id == request.auth.uid))
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() || 
        (resource != null && request.auth.uid in resource.data.assignedVerifierIds)
      );
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}