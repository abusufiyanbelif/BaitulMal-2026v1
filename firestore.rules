rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Simplified rules for institutional transparency and ease of management.
    // Public users can read everything to see verified stats and published campaigns.
    // Authenticated members have full control over data.
    
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}