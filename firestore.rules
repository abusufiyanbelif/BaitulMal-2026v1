
// RE-DEPLOY CACHE BUSTER
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Unrestricted testing rules for authenticated members as requested during stabilization
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Explicit list grant for verification pipeline
    match /pending_verifications/{id} {
      allow list: if request.auth != null;
    }
  }
}
