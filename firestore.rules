rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function hasPermission(module, perm) {
      return isSignedIn() && (isAdmin() || getUserData().permissions[module][perm] == true);
    }

    // --- RULES ---

    // Public Visibility Settings
    match /settings/branding { allow read: if true; }
    match /settings/payment { allow read: if true; }
    match /settings/info { allow read: if true; }
    match /settings/donationInfo { allow read: if true; }
    match /settings/guidance { allow read: if true; }
    match /settings/guidingPrinciples { allow read: if true; }
    
    // Admin Settings
    match /settings/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // User Registry & Lookups
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId || hasPermission('users', 'read'));
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId && isActive());
    }

    // Campaigns & Leads
    match /campaigns/{id} {
      allow read: if hasPermission('campaigns', 'read') || resource.data.publicVisibility == 'Published';
      allow write: if hasPermission('campaigns', 'update') || hasPermission('campaigns', 'create');
    }
    
    match /campaigns/{id}/beneficiaries/{benId} {
      allow read: if hasPermission('campaigns', 'beneficiaries', 'read');
      allow write: if hasPermission('campaigns', 'beneficiaries', 'update');
    }

    match /leads/{id} {
      allow read: if hasPermission('leads-members', 'read') || resource.data.publicVisibility == 'Published';
      allow write: if hasPermission('leads-members', 'update') || hasPermission('leads-members', 'create');
    }
    
    match /leads/{id}/beneficiaries/{benId} {
      allow read: if hasPermission('leads-members', 'beneficiaries', 'read');
      allow write: if hasPermission('leads-members', 'beneficiaries', 'update');
    }

    // Donations & Donors
    match /donations/{id} {
      allow read: if hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'update') || hasPermission('donations', 'create');
    }
    
    match /donors/{id} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'update') || hasPermission('donors', 'create');
    }

    // Beneficiaries Master
    match /beneficiaries/{id} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'update') || hasPermission('beneficiaries', 'create');
    }

    // Verification Pipeline
    match /pending_verifications/{id} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      allow create: if isSignedIn() && isActive();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }
    
    // Page Hits Analytics
    match /page_hits/{id} {
      allow read: if hasPermission('analytics', 'read');
      allow write: if true; // Public can increment hits
    }
  }
}