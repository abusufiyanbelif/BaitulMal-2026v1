rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DocuExtract Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict User-Ownership model. The application is designed to be 
     * a private document management and extraction tool where users exclusively interact 
     * with their own data.
     *
     * DATA STRUCTURE:
     * All application data is organized in a deep hierarchy under the user's primary 
     * document: /users/{userId}. Subcollections for documents and various extraction 
     * types (identity, billing, medical) are nested within this path to ensure 
     * authorization context is always available via the request path.
     *
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Authorization: We use the {userId} wildcard in the document path to 
     *    grant access, comparing it directly against request.auth.uid. This avoids 
     *    expensive get() calls and ensures high performance.
     * 2. No Global Access: There are no top-level public collections. Listing users 
     *    is strictly forbidden.
     * 3. Relational Integrity: On document creation, we verify that the internal 
     *    ownership fields (like userId or parent IDs) match the values provided in the 
     *    secure request path.
     * 4. Prototyping Mode: Rules are strict on WHO can access data but flexible on 
     *    WHAT the data looks like (schema-agnostic) to support rapid development.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the signed-in user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the top-level user profile.
     * @path /users/{userId}
     * @allow (get) If the authenticated user's UID matches {userId}.
     * @deny (list) All attempts to list user profiles.
     * @principle Restricts access to a user's own profile and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for documents uploaded by the user.
       * @path /users/{userId}/documents/{documentId}
       * @allow (create) If the user owns the path and sets their userId correctly in the data.
       * @deny (write) If the userId in the data does not match the authenticated user.
       * @principle Enforces document ownership via path-based scoping and relational integrity.
       */
      match /documents/{documentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for raw text extracted from a document.
         * @path /users/{userId}/documents/{documentId}/extractedTexts/{extractedTextId}
         * @allow (create) If the user owns the path and links the correct parent documentId.
         * @deny (update) If an attempt is made to change the parent documentId link.
         * @principle Inherits authorization from the user-scoped document path.
         */
        match /extractedTexts/{extractedTextId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId) && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for identity proof extractions.
         * @path /users/{userId}/documents/{documentId}/identityProofExtractions/{id}
         * @allow (get) If the owner of the parent document requests the data.
         * @deny (delete) If the user is not the owner of the document path.
         * @principle Ensures sensitive extraction data is only visible to the document owner.
         */
        match /identityProofExtractions/{identityProofExtractionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId) && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for billing statement summary extractions.
         * @path /users/{userId}/documents/{documentId}/billingStatementExtractions/{id}
         * @allow (list) The owner can list all bill extractions for a document.
         * @deny (create) If the documentId in the body mismatches the path.
         * @principle Maintains path-to-data consistency for billing records.
         */
        match /billingStatementExtractions/{billingStatementExtractionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId) && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);

          /**
           * @description Rules for line items within a billing statement.
           * @path /users/{userId}/documents/{documentId}/billingStatementExtractions/{billingStatementExtractionId}/lineItems/{id}
           * @allow (update) The owner can correct line item details.
           * @deny (get) Unauthenticated access.
           * @principle Deeply nested authorization inheritance.
           */
          match /lineItems/{billingLineItemId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId) && request.resource.data.billingStatementExtractionId == billingStatementExtractionId;
            allow update: if isExistingOwner(userId) && request.resource.data.billingStatementExtractionId == resource.data.billingStatementExtractionId;
            allow delete: if isExistingOwner(userId);
          }
        }

        /**
         * @description Rules for medical report extractions.
         * @path /users/{userId}/documents/{documentId}/medicalReportExtractions/{id}
         * @allow (create) If the user is authenticated and the path is their own.
         * @deny (update) If the user tries to modify the record of another user.
         * @principle Protects health-related information through strict ownership.
         */
        match /medicalReportExtractions/{medicalReportExtractionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.documentId == documentId;
          allow update: if isExistingOwner(userId) && request.resource.data.documentId == resource.data.documentId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}