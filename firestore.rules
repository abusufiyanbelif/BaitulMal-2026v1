
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, action) {
      let perms = getUserData().permissions;
      return isAdmin() || (isSignedIn() && perms[module][action] == true);
    }

    // --- Institutional Settings (Publicly Readable) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- User Management & Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasPermission('users', 'read'));
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
    
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin() || isSignedIn();
    }

    // --- Donor Module ---
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'create') || hasPermission('donors', 'update');
      allow delete: if hasPermission('donors', 'delete');
    }

    // --- Donation Registry ---
    match /donations/{donationId} {
      allow read: if true; // Public summaries need access to verified totals
      allow create: if hasPermission('donations', 'create');
      allow update: if hasPermission('donations', 'update');
      allow delete: if hasPermission('donations', 'delete');
    }

    // --- Beneficiary Registry ---
    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update');
      allow delete: if hasPermission('beneficiaries', 'delete');
    }

    // --- Campaigns ---
    match /campaigns/{campId} {
      allow read: if true;
      allow write: if hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update');
      allow delete: if hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    // --- Leads ---
    match /leads/{leadId} {
      allow read: if true;
      allow write: if hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update');
      allow delete: if hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if hasPermission('leads-members', 'update');
      }
    }
    
    // --- Page Hits (Analytics) ---
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
