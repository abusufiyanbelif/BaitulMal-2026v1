rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, action) {
      return isAdmin() || (isSignedIn() && getUserData().permissions[module][action] == true);
    }

    // Settings are mostly public for branding and guidance
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns & Leads: Public can see verified/published summaries
    match /campaigns/{campaignId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') || hasPermission('campaigns', 'read');
      allow create: if hasPermission('campaigns', 'create');
      allow update: if hasPermission('campaigns', 'update');
      allow delete: if hasPermission('campaigns', 'delete');

      match /beneficiaries/{benId} {
        allow read: if hasPermission('campaigns', 'read');
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    match /leads/{leadId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') || hasPermission('leads-members', 'read');
      allow create: if hasPermission('leads-members', 'create');
      allow update: if hasPermission('leads-members', 'update');
      allow delete: if hasPermission('leads-members', 'delete');

      match /beneficiaries/{benId} {
        allow read: if hasPermission('leads-members', 'read');
        allow write: if hasPermission('leads-members', 'update');
      }
    }

    // Donations: Public can see verified amounts for progress tracking
    match /donations/{donationId} {
      allow read: if (resource.data.status == 'Verified') || hasPermission('donations', 'read');
      allow create: if hasPermission('donations', 'create');
      allow update: if hasPermission('donations', 'update');
      allow delete: if hasPermission('donations', 'delete');
    }

    // Private Registries
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'update');
      allow delete: if hasPermission('donors', 'delete');
    }

    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'update');
      allow delete: if hasPermission('beneficiaries', 'delete');
    }

    // Team directory is public, but specific PII is gated
    match /users/{userId} {
      allow read: if (resource.data.organizationGroup != null && resource.data.status == 'Active') || isSignedIn();
      allow write: if isAdmin();
    }

    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin() || !isSignedIn();
    }
    
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}