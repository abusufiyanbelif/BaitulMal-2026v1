rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'; }
    function hasPermission(module, perm) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.role == 'Admin' || (user.permissions != null && user.permissions[module][perm] == true);
    }

    // Settings (Branding, Info, Guidance)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users & Lookups
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Donors
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'create') || hasPermission('donors', 'update');
      allow delete: if hasPermission('donors', 'delete');
    }

    // Donations
    match /donations/{donationId} {
      allow read: if true;
      allow write: if isSignedIn();
      allow delete: if hasPermission('donations', 'delete');
    }

    // Campaigns & Leads
    match /campaigns/{id} {
      allow read: if true;
      allow write: if hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update');
      allow delete: if hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }
    match /leads/{id} {
      allow read: if true;
      allow write: if hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update');
      allow delete: if hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // Master Beneficiaries
    match /beneficiaries/{id} {
      allow read: if true;
      allow write: if isSignedIn();
      allow delete: if hasPermission('beneficiaries', 'delete');
    }
    
    // Page Analytics
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}