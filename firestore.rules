rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (getUserData().role == 'Admin' || request.auth.uid == 'admin');
    }

    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }

    function hasPermission(module, action) {
      let permissions = getUserData().permissions;
      return isAdmin() || (isActive() && permissions[module][action] == true);
    }

    // --- Collection Rules ---

    // Organizational Settings (Publicly readable, Admin writable)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Registry & Lookups
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || hasPermission('users', 'read'));
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns Module
    match /campaigns/{campaignId} {
      allow read: if true; // Public initiatives are visible to all
      allow create: if isAdmin() || hasPermission('campaigns', 'create');
      allow update: if isAdmin() || hasPermission('campaigns', 'update');
      allow delete: if isAdmin() || hasPermission('campaigns', 'delete');

      match /beneficiaries/{beneficiaryId} {
        allow read: if isAdmin() || hasPermission('campaigns', 'read');
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }

    // Leads Module
    match /leads/{leadId} {
      allow read: if true; 
      allow create: if isAdmin() || hasPermission('leads-members', 'create');
      allow update: if isAdmin() || hasPermission('leads-members', 'update');
      allow delete: if isAdmin() || hasPermission('leads-members', 'delete');

      match /beneficiaries/{beneficiaryId} {
        allow read: if isAdmin() || hasPermission('leads-members', 'read');
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    // Donors & Donations
    match /donors/{donorId} {
      allow read: if isSignedIn() && (request.auth.uid == donorId || isAdmin() || hasPermission('donors', 'read'));
      allow write: if isAdmin() || hasPermission('donors', 'update') || (isSignedIn() && request.auth.uid == donorId);
    }

    match /donations/{donationId} {
      allow read: if isSignedIn() && (isAdmin() || hasPermission('donations', 'read') || resource.data.donorId == request.auth.uid);
      allow create: if isSignedIn(); // Allow authenticated users to record donations
      allow update: if isAdmin() || hasPermission('donations', 'update');
      allow delete: if isAdmin() || hasPermission('donations', 'delete');
    }

    // Master Beneficiary Registry
    match /beneficiaries/{beneficiaryId} {
      allow read: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'read'));
      allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }

    // Verification Pipeline
    match /pending_verifications/{requestId} {
      // Admins can see all. Members can only see those where they are assigned as verifiers.
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      // List permission matching the query in the UI
      allow list: if isSignedIn() && (isAdmin() || request.query.limit <= 100); 
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }

    // Analytics & Telemetry
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true; // Public incrementing
    }
  }
}
