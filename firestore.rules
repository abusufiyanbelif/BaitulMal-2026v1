rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DocuExtract Security Rules
     *
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model. Every piece of data—from user profiles
     * to document extractions—is nested under a specific user's root path (/users/{userId}).
     *
     * Data Structure:
     * The hierarchy follows: /users/{userId} -> /documents/{documentId} -> {ExtractionSubcollections}.
     * All access is strictly partitioned by the Firebase Authentication UID.
     *
     * Key Security Decisions:
     * 1. Authorization Independence: Every document in a subcollection denormalizes its parent
     *    identifiers (userId, documentId). This allows rules to perform fast, local checks
     *    without expensive get() calls to parent documents.
     * 2. Prototyping Flexibility: Rules strictly enforce 'who' can write data (ownership) and
     *    'relational integrity' (correct links), but do not enforce strict schema types or
     *    optional fields to allow for rapid frontend iteration.
     * 3. Default Privacy: No data is public. All read and write operations require authentication
     *    and must match the user's own data tree.
     *
     * Denormalization for Authorization:
     * To ensure performance and reliability, relational fields like 'userId' and 'documentId'
     * are validated upon creation to match the document's path and are enforced as
     * immutable during updates.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /**
     * @description Checks if the request is from a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Combines ownership check with a check for the document's existence.
     * Used for update and delete operations to ensure destructive actions only occur on existing data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Validates that the userId in the data matches the userId in the path.
     */
    function isValidUserLink(dataUserId, pathUserId) {
      return dataUserId == pathUserId;
    }

    /**
     * @description Validates that the documentId in the data matches the documentId in the path.
     */
    function isValidDocumentLink(dataDocId, pathDocId) {
      return dataDocId == pathDocId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for User profiles. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow (create) User 'abc' creates document /users/abc if auth.uid is 'abc'.
     * @deny (read) User 'abc' tries to get /users/xyz.
     * @principle Self-Creation and Ownership.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for Documents uploaded by a user.
       * @path /users/{userId}/documents/{documentId}
       * @allow (create) User 'abc' uploads a doc where 'userId' field in data is 'abc'.
       * @deny (update) User 'abc' tries to change the 'userId' field of an existing document.
       * @principle Structural segregation and relational integrity.
       */
      match /documents/{documentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserLink(request.resource.data.userId, userId);
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for raw text extracted from a document.
         * @path /users/{userId}/documents/{documentId}/extractedTexts/{extractedTextId}
         * @allow (create) Creating text data linked correctly to the parent document and user.
         * @deny (list) Listing texts if the userId in the path doesn't match the auth UID.
         * @principle Authorization Independence via denormalized fields.
         */
        match /extractedTexts/{extractedTextId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserLink(request.resource.data.userId, userId) && isValidDocumentLink(request.resource.data.documentId, documentId);
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for extracted identity proof details.
         * @path /users/{userId}/documents/{documentId}/identityProofExtractions/{id}
         * @allow (get) Owner retrieves their own extraction results.
         * @deny (create) User 'abc' tries to create extraction for user 'xyz' via path manipulation.
         * @principle Path-based and Resource-based ownership.
         */
        match /identityProofExtractions/{id} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserLink(request.resource.data.userId, userId) && isValidDocumentLink(request.resource.data.documentId, documentId);
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for billing statement extractions.
         * @path /users/{userId}/documents/{documentId}/billingStatementExtractions/{id}
         * @allow (update) User corrects an extracted vendor name.
         * @deny (delete) Deleting a document that doesn't exist.
         * @principle Relational integrity and existence verification.
         */
        match /billingStatementExtractions/{id} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserLink(request.resource.data.userId, userId) && isValidDocumentLink(request.resource.data.documentId, documentId);
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);

          /**
           * @description Rules for individual line items within a billing statement.
           * @path /users/{userId}/documents/{documentId}/billingStatementExtractions/{id}/lineItems/{lineItemId}
           * @allow (create) Creating a line item linked to its grandparent Document and User.
           * @deny (update) Changing the parent billing extraction ID.
           * @principle Deeply nested relational integrity.
           */
          match /lineItems/{lineItemId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId) && isValidUserLink(request.resource.data.userId, userId) && isValidDocumentLink(request.resource.data.documentId, documentId) && request.resource.data.billingStatementExtractionId == id;
            allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.billingStatementExtractionId == resource.data.billingStatementExtractionId;
            allow delete: if isExistingOwner(userId);
          }
        }

        /**
         * @description Rules for extracted medical report details.
         * @path /users/{userId}/documents/{documentId}/medicalReportExtractions/{id}
         * @allow (list) Owner views all medical extractions for a specific document.
         * @deny (create) Mismatched userId between auth state and document data.
         * @principle Ownership-based list protection.
         */
        match /medicalReportExtractions/{id} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserLink(request.resource.data.userId, userId) && isValidDocumentLink(request.resource.data.documentId, documentId);
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}