rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getProfile().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getProfile().status == 'Active';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function hasPermission(module, action) {
      let perms = getProfile().permissions;
      return isAdmin() || (perms != null && perms[module][action] == true);
    }

    // --- RULES ---

    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || isOwner(userId) || hasPermission('users', 'read'));
      allow create: if isAdmin();
      allow update: if isSignedIn() && (isAdmin() || isOwner(userId) || hasPermission('users', 'update'));
      allow delete: if isAdmin();
    }
    
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /donors/{donorId} {
      allow read: if isSignedIn() && (isAdmin() || isOwner(donorId) || hasPermission('donors', 'read'));
      allow write: if isAdmin() || hasPermission('donors', 'update');
    }
    
    match /donations/{donationId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.donorId == request.auth.uid || 
        hasPermission('donations', 'read')
      );
      allow create: if isActive() && (isAdmin() || hasPermission('donations', 'create'));
      allow update: if isActive() && (isAdmin() || hasPermission('donations', 'update'));
      allow delete: if isAdmin();
    }
    
    match /campaigns/{campaignId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') || (isSignedIn() && hasPermission('campaigns', 'read'));
      allow write: if isActive() && (isAdmin() || hasPermission('campaigns', 'update'));
      
      match /beneficiaries/{benId} {
        allow read: if isSignedIn() && (isAdmin() || hasPermission('campaigns', 'read'));
        allow write: if isActive() && (isAdmin() || hasPermission('campaigns', 'update'));
      }
    }
    
    match /leads/{leadId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') || (isSignedIn() && hasPermission('leads-members', 'read'));
      allow write: if isActive() && (isAdmin() || hasPermission('leads-members', 'update'));
      
      match /beneficiaries/{benId} {
        allow read: if isSignedIn() && (isAdmin() || hasPermission('leads-members', 'read'));
        allow write: if isActive() && (isAdmin() || hasPermission('leads-members', 'update'));
      }
    }
    
    match /beneficiaries/{benId} {
      allow read: if isSignedIn() && (isAdmin() || hasPermission('beneficiaries', 'read'));
      allow create: if isActive() && (isAdmin() || hasPermission('beneficiaries', 'create'));
      allow update: if isActive() && (isAdmin() || hasPermission('beneficiaries', 'update'));
      allow delete: if isAdmin();
    }
    
    match /pending_verifications/{id} {
      allow read: if isSignedIn() && (isAdmin() || (request.auth.uid in resource.data.assignedVerifierIds));
      allow create: if isActive() && (isAdmin() || hasPermission('donations', 'update') || hasPermission('campaigns', 'update') || hasPermission('leads-members', 'update') || hasPermission('donors', 'update'));
      allow update: if isActive() && (isAdmin() || (request.auth.uid in resource.data.assignedVerifierIds));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.requestedBy.id == request.auth.uid);
    }
    
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /page_hits/{id} {
      allow read, write: if true;
    }
  }
}