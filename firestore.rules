rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared validation functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, action) {
      return isSignedIn() && (getUserData().role == 'Admin' || getUserData().permissions[module][action] == true);
    }

    // Public settings
    match /settings/branding {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/payment {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/info {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/donationInfo {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/guidingPrinciples {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/guidance {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/campaign_visibility {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/lead_visibility {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/lead_config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /settings/campaign_config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /settings/donation_config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /settings/beneficiary_config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /settings/user_config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Auth lookup map
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User management
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || hasPermission('users', 'read'));
      allow write: if isAdmin() || (request.auth.uid == userId);
    }

    // Community members (Donors)
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'update') || hasPermission('donors', 'create');
      allow delete: if isAdmin() || hasPermission('donors', 'delete');
    }

    // Financial records
    match /donations/{donationId} {
      allow read: if hasPermission('donations', 'read') || (isSignedIn() && request.auth.uid == resource.data.donorId);
      allow create: if hasPermission('donations', 'create');
      allow update: if hasPermission('donations', 'update');
      allow delete: if isAdmin() || hasPermission('donations', 'delete');
    }

    // Beneficiaries (Master List)
    match /beneficiaries/{beneficiaryId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow create: if hasPermission('beneficiaries', 'create');
      allow update: if hasPermission('beneficiaries', 'update');
      allow delete: if isAdmin() || hasPermission('beneficiaries', 'delete');
    }

    // Initiatives (Campaigns)
    match /campaigns/{campaignId} {
      allow read: if true; // Public can see campaigns
      allow write: if hasPermission('campaigns', 'update') || hasPermission('campaigns', 'create');
      allow delete: if isAdmin() || hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{id} {
        allow read: if isSignedIn();
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    // Initiatives (Leads)
    match /leads/{leadId} {
      allow read: if true; // Public can see published leads
      allow write: if hasPermission('leads-members', 'update') || hasPermission('leads-members', 'create');
      allow delete: if isAdmin() || hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{id} {
        allow read: if isSignedIn();
        allow write: if hasPermission('leads-members', 'update');
      }
    }
    
    // Page hit tracking
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
