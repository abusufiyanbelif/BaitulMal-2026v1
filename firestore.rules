rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Global Public Read Access
    // This allows verified statistics and public campaigns to load without errors
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}