rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Centralized Security Helpers ---
    function isSignedIn() { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isActive() { return isSignedIn() && getUserData().status == 'Active'; }
    function isAdmin() { return isSignedIn() && getUserData().role == 'Admin'; }
    
    function hasPermission(module, action) {
      return isAdmin() || (isSignedIn() && getUserData().permissions[module][action] == true);
    }

    // --- Institutional Configuration ---
    match /settings/{docId} {
      allow read: if true; // Branding, Payment, Info are public
      allow write: if isAdmin();
    }

    match /user_lookups/{id} {
      allow read: if true; // Publicly needed for login discovery
      allow write: if isAdmin();
    }

    // --- Identity & Access ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasPermission('users', 'read'));
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'create') || hasPermission('donors', 'update');
    }

    match /donations/{donationId} {
      allow read: if hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'create') || hasPermission('donations', 'update');
    }

    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update');
    }

    // --- Initiatives ---
    match /campaigns/{campId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') || hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{subBenId} {
        allow read: if hasPermission('campaigns', 'read');
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    match /leads/{leadId} {
      allow read: if (resource.data.publicVisibility == 'Published' && resource.data.authenticityStatus == 'Verified') || hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{subBenId} {
        allow read: if hasPermission('leads-members', 'read');
        allow write: if hasPermission('leads-members', 'update');
      }
    }

    // --- Verification Pipeline ---
    match /pending_verifications/{reqId} {
      // Critical fix for "list" error: Admins see all, Members see only assigned tasks.
      // Filter must be applied in the frontend query to match these rules.
      allow list: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds;
      allow delete: if isAdmin();
    }
    
    match /page_hits/{pageId} {
      allow read: if isAdmin() || hasPermission('analytics', 'read');
      allow write: if true; // Public incrementing allowed
    }
  }
}