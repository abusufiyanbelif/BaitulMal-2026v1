rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- AUTHENTICATION HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // ADMINISTRATIVE IDENTITY BYPASS
    // Specifically grants superuser status to Maaz Shaikh and BaitulMal System Admin identities.
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'abusufiyan.belif@gmail.com' ||
        request.auth.token.email == 'baitulmalss.solapur@gmail.com' ||
        request.auth.uid == 'cyMl1lQME0Yur1YS3VCms1AvrOJ2' ||
        request.auth.uid == 'S5efNV5jpTPoxYNv6SnAlv3jNPO2' ||
        request.auth.uid == '3gKwUE2JrBT8wngoUxTTN6tLJk03'
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    function isStaff() {
      return isAdmin() || (
        isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'User'
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || request.auth.uid == userId;
    }

    match /user_lookups/{lookupId} {
      allow read: if true; // Public for login discovery
      allow write: if isAdmin();
    }

    match /donors/{donorId} {
      allow read: if isStaff() || request.auth.uid == donorId;
      allow write: if isStaff() || request.auth.uid == donorId;
    }

    match /donations/{donationId} {
      allow read: if isStaff() || resource.data.donorId == request.auth.uid;
      allow create: if isSignedIn(); // Allow public gateway or staff
      allow update, delete: if isStaff();
    }

    match /beneficiaries/{beneficiaryId} {
      allow read: if isStaff() || request.auth.uid == beneficiaryId;
      allow create: if isSignedIn();
      allow update, delete: if isStaff();
    }

    match /campaigns/{campaignId} {
      allow read: if true; // Public visibility
      allow write: if isStaff();
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isStaff();
      }
    }

    match /leads/{leadId} {
      allow read: if true; // Public visibility
      allow write: if isStaff();
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isStaff();
      }
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /page_hits/{pageId} {
      allow read, write: if true; // Analytics bypass
    }

    match /pending_verifications/{requestId} {
      // Members must be able to list verifications assigned to them
      allow read: if isSignedIn();
      // Any member can submit a request for verification
      allow create: if isSignedIn();
      // Only admins or assigned verifiers can update status
      allow update, delete: if isStaff();
    }
  }
}
