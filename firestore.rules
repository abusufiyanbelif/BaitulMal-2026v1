rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is the user a global Admin?
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Helper: Is the user's account Active?
    function isActive() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'Active';
    }

    // Helper: Does the user have a specific module permission?
    function hasPermission(module, p) {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[module][p] == true;
    }

    // Public Collections (Logo, Branding, Global Settings)
    match /settings/branding {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/payment {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // User Lookups (Publicly readable for sign-in discovery)
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || hasPermission('users', 'read'));
      allow write: if isAdmin();
      allow update: if request.auth != null && request.auth.uid == userId; // Allow self-update for profile
    }

    // Donors
    match /donors/{donorId} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('donors', 'read') || request.auth.uid == donorId);
      allow write: if isAdmin() || (isActive() && hasPermission('donors', 'create'));
    }

    // Beneficiaries
    match /beneficiaries/{beneficiaryId} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('beneficiaries', 'read'));
      allow write: if isAdmin() || (isActive() && hasPermission('beneficiaries', 'create'));
    }

    // Donations
    match /donations/{donationId} {
      allow read: if request.auth != null && (isAdmin() || hasPermission('donations', 'read') || resource.data.donorId == request.auth.uid);
      allow write: if isAdmin() || (isActive() && hasPermission('donations', 'create'));
    }

    // Campaigns & Subcollections
    match /campaigns/{campaignId} {
      allow read: if (resource.data.publicVisibility == 'Published') || (request.auth != null && (isAdmin() || hasPermission('campaigns', 'read')));
      allow write: if isAdmin() || (isActive() && hasPermission('campaigns', 'create'));
      
      match /beneficiaries/{benId} {
        allow read: if request.auth != null && (isAdmin() || hasPermission('campaigns', 'read'));
        allow write: if isAdmin() || (isActive() && hasPermission('campaigns', 'update'));
      }
    }

    // Leads & Subcollections
    match /leads/{leadId} {
      allow read: if (resource.data.publicVisibility == 'Published') || (request.auth != null && (isAdmin() || hasPermission('leads-members', 'read')));
      allow write: if isAdmin() || (isActive() && hasPermission('leads-members', 'create'));
      
      match /beneficiaries/{benId} {
        allow read: if request.auth != null && (isAdmin() || hasPermission('leads-members', 'read'));
        allow write: if isAdmin() || (isActive() && hasPermission('leads-members', 'update'));
      }
    }

    // Verification Requests
    match /pending_verifications/{requestId} {
      // Non-admins can only see requests where they are assigned verifiers.
      allow read: if request.auth != null && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      allow create: if request.auth != null && isActive();
      allow update: if request.auth != null && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }
    
    // Page Hits (Analytics)
    match /page_hits/{pageId} {
      allow read, write: if true; 
    }
  }
}