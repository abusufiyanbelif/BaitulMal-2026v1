rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Admin";
    }
    
    function hasPermission(module, action) {
      let permissions = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions;
      return isAdmin() || (isSignedIn() && permissions[module][action] == true);
    }

    // Settings: Public read, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Lookups: Public read (for login routing), Admin write
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (request.auth.uid == userId);
    }

    // Donors
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'create') || hasPermission('donors', 'update') || hasPermission('donors', 'delete');
    }

    // Campaigns & Leads: Public read if published, otherwise member only
    match /campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == "Published" || hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update') || hasPermission('campaigns', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if hasPermission('campaigns', 'read');
        allow write: if hasPermission('campaigns', 'update');
      }
    }

    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == "Published" || hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update') || hasPermission('leads-members', 'delete');
      
      match /beneficiaries/{benId} {
        allow read: if hasPermission('leads-members', 'read');
        allow write: if hasPermission('leads-members', 'update');
      }
    }

    // Master Beneficiaries
    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update') || hasPermission('beneficiaries', 'delete');
    }

    // Donations
    match /donations/{donId} {
      allow read: if hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'create') || hasPermission('donations', 'update') || hasPermission('donations', 'delete');
    }
    
    // Page Hits: Public increment
    match /page_hits/{pageId} {
      allow read: if isAdmin();
      allow write: if true; 
    }
  }
}