rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for institutional logic
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function hasPermission(module, permission) {
      let permissions = getUserData().permissions;
      return isAdmin() || (permissions != null && permissions.keys().contains(module) && permissions[module][permission] == true);
    }

    // --- Core Registry Access ---

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow write: if isAdmin() || (request.auth.uid == userId && isActive());
    }
    
    match /user_lookups/{lookupId} {
      allow read: if true; // Public access required for login email discovery
      allow write: if isAdmin();
    }
    
    match /donors/{donorId} {
      allow read: if isAdmin() || hasPermission('donors', 'read') || request.auth.uid == donorId;
      allow write: if isAdmin() || hasPermission('donors', 'create') || hasPermission('donors', 'update');
    }
    
    match /donations/{donationId} {
      allow read: if isAdmin() || hasPermission('donations', 'read') || (request.auth != null && resource.data.donorId == request.auth.uid);
      allow write: if isAdmin() || hasPermission('donations', 'create') || hasPermission('donations', 'update');
    }
    
    match /beneficiaries/{beneficiaryId} {
      allow read: if isAdmin() || hasPermission('beneficiaries', 'read') || request.auth.uid == beneficiaryId;
      allow write: if isAdmin() || hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update');
    }

    // --- Initiative Access (Campaigns & Leads) ---
    
    match /campaigns/{campaignId} {
      allow read: if true; // Public can read published content
      allow write: if isAdmin() || hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if isAdmin() || hasPermission('campaigns', 'read');
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }
    
    match /leads/{leadId} {
      allow read: if true; // Public can read published content
      allow write: if isAdmin() || hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if isAdmin() || hasPermission('leads-members', 'read');
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    // --- System & Audit Hub ---
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /pending_verifications/{requestId} {
      // Non-admins must strictly filter by assignedVerifierIds in their query to succeed.
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow create: if isActive();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }
    
    match /page_hits/{pageId} {
      allow read, write: if true; // Public analytics
    }
  }
}