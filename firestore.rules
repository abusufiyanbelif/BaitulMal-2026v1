rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'Admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasPermission(module, permission) {
      let permissions = getUserData().permissions;
      return permissions != null && permissions[module] != null && permissions[module][permission] == true;
    }

    // --- Collection Rules ---

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }
    
    match /donors/{donorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasPermission('donors', 'update');
    }
    
    match /donations/{donationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasPermission('donations', 'update');
    }
    
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || hasPermission('campaigns', 'beneficiaries.update');
      }
    }
    
    match /leads/{leadId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || hasPermission('leads-members', 'beneficiaries.update');
      }
    }
    
    match /beneficiaries/{benId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasPermission('beneficiaries', 'update');
    }
    
    match /pending_verifications/{id} {
      // Allow read/get if admin, assigned verifier, or requester
      allow read: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid in resource.data.assignedVerifierIds || 
        request.auth.uid == resource.data.requestedBy.id
      );
      
      // Mandatory: list requires filter by assignedVerifierIds unless Admin
      allow list: if isSignedIn() && (
        isAdmin() || 
        (request.query.limit <= 100 && request.auth.uid in resource.data.assignedVerifierIds)
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }
    
    match /page_hits/{id} {
      allow read: if isAdmin();
      allow write: if true; // Increments happen anonymously
    }
  }
}
