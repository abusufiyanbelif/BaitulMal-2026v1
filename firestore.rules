
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is the user an Admin?
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Helper: Check for granular module permissions
    function hasPermission(module, permission) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.role == 'Admin' || (
        user.permissions.keys().contains(module) && 
        user.permissions[module].keys().contains(permission) && 
        user.permissions[module][permission] == true
      );
    }

    // Helper: Check for sub-module permissions
    function hasSubPermission(module, subModule, permission) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.role == 'Admin' || (
        user.permissions.keys().contains(module) &&
        user.permissions[module].keys().contains(subModule) &&
        user.permissions[module][subModule].keys().contains(permission) &&
        user.permissions[module][subModule][permission] == true
      );
    }

    // --- USERS & LOOKUPS ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || hasPermission('users', 'write');
    }

    match /user_lookups/{lookupId} {
      allow read: if true; // Public lookup for custom login
      allow write: if isAdmin() || hasPermission('users', 'write');
    }

    // --- CAMPAIGNS ---
    match /campaigns/{campaignId} {
      allow read: if isSignedIn() || resource.data.publicVisibility == 'Published';
      allow write: if isAdmin() || hasPermission('campaigns', 'write');

      match /beneficiaries/{beneficiaryId} {
        // Allow public to see beneficiary lists if campaign is published
        allow read: if isSignedIn() || get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published';
        allow write: if isAdmin() || hasSubPermission('campaigns', 'beneficiaries', 'write');
      }
    }

    // --- LEADS ---
    match /leads/{leadId} {
      allow read: if isSignedIn() || resource.data.publicVisibility == 'Published';
      allow write: if isAdmin() || hasPermission('leads-members', 'write');

      match /beneficiaries/{beneficiaryId} {
        // Allow public to see beneficiary lists if lead is published
        allow read: if isSignedIn() || get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published';
        allow write: if isAdmin() || hasSubPermission('leads-members', 'beneficiaries', 'write');
      }
    }

    // --- MASTER BENEFICIARIES ---
    match /beneficiaries/{beneficiaryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasPermission('beneficiaries', 'write');
    }

    // --- DONORS ---
    match /donors/{donorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasPermission('donors', 'write');
    }

    // --- DONATIONS ---
    match /donations/{donationId} {
      // Verified donations are listable by public for impact tracking
      allow list: if true;
      allow get: if isSignedIn();
      allow create, update, delete: if isAdmin() || hasPermission('donations', 'write');
    }

    // --- SYSTEM SETTINGS ---
    match /settings/{settingId} {
      allow read: if true; // Public settings (branding, etc.)
      allow write: if isAdmin();
    }

    // --- ANALYTICS ---
    match /page_hits/{pageId} {
      allow read, write: if true; // Public hit counter
    }
  }
}
