rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }

    // Public Settings
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Lookups
    match /user_lookups/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Donors Collection
    match /donors/{donorId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isActive();
    }

    // Donations Collection
    match /donations/{donationId} {
      allow read: if true; // Publicly readable for summary charts
      allow write: if isSignedIn() && isActive();
    }

    // Beneficiaries Collection
    match /beneficiaries/{beneficiaryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isActive();
    }

    // Campaigns & Subcollections
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isSignedIn() && isActive();
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isSignedIn() && isActive();
      }
    }

    // Leads & Subcollections
    match /leads/{leadId} {
      allow read: if true;
      allow write: if isSignedIn() && isActive();
      
      match /beneficiaries/{benId} {
        allow read: if true;
        allow write: if isSignedIn() && isActive();
      }
    }

    // Verification Pipeline
    match /pending_verifications/{id} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds || request.auth.uid == resource.data.requestedBy.id);
      allow create: if isSignedIn() && isActive();
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isSignedIn() && isAdmin();
    }

    // Analytics
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}