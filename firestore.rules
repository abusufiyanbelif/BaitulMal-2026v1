rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'; }
    function hasPermission(module, action) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAdmin() || (user.permissions != null && user.permissions[module][action] == true);
    }

    // Public Institutional Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Donor & User Identity
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (request.auth.uid == userId);
    }
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /donors/{donorId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('donors', 'update') || hasPermission('donors', 'create');
    }

    // Operational Modules
    match /campaigns/{campId} {
      allow read: if true;
      allow write: if hasPermission('campaigns', 'update');
      match /beneficiaries/{benId} {
        allow read: if isSignedIn();
        allow write: if hasPermission('campaigns', 'update');
      }
    }
    match /leads/{leadId} {
      allow read: if true;
      allow write: if hasPermission('leads-members', 'update');
      match /beneficiaries/{benId} {
        allow read: if isSignedIn();
        allow write: if hasPermission('leads-members', 'update');
      }
    }
    match /donations/{donId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('donations', 'create') || hasPermission('donations', 'update');
    }
    match /beneficiaries/{benId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update');
    }
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}
