    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, permission) {
      if (!isSignedIn()) return false;
      let user = getUserData();
      if (user.role == 'Admin') return true;
      
      // Handle nested permission paths (e.g., 'settings.info.update')
      let parts = module.split('\\.');
      if (parts.size() == 1) {
        return user.permissions[module][permission] == true;
      } else if (parts.size() == 2) {
        return user.permissions[parts[0]][parts[1]][permission] == true;
      }
      return false;
    }
    
