rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is the user a signed-in Admin?
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Helper: Does the user have a specific permission?
    function hasPermission(module, action) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.role == 'Admin' || (user.permissions != null && user.permissions[module][action] == true);
    }

    // Helper: Is the user the owner of this document?
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Public Visibility Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || hasPermission('users', 'read');
      allow create: if isAdmin() || hasPermission('users', 'create');
      allow update: if isOwner(userId) || hasPermission('users', 'update');
      allow delete: if isAdmin();
    }

    // Lookup Table (Email discovery for Login)
    match /user_lookups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns & Leads
    match /{path=**}/campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'update');
    }
    
    match /{path=**}/leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'update');
    }

    // Nested Beneficiaries & Donations
    match /{path=**}/beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read') || hasPermission('campaigns', 'read') || hasPermission('leads-members', 'read');
      allow write: if hasPermission('beneficiaries', 'update') || hasPermission('campaigns', 'update') || hasPermission('leads-members', 'update');
    }

    match /donations/{donationId} {
      allow read: if hasPermission('donations', 'read') || (request.auth != null && request.auth.uid == resource.data.donorId);
      allow write: if hasPermission('donations', 'update');
    }

    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read') || isOwner(donorId) || (request.auth != null && request.auth.uid == resource.data.linkedUserId);
      allow write: if hasPermission('donors', 'update');
    }

    // Verification Pipeline
    match /pending_verifications/{requestId} {
      // Admins can list all. Members can list if they are in the assigned array.
      allow list: if isAdmin() || (request.auth != null && request.auth.uid in resource.data.assignedVerifierIds);
      allow get: if isAdmin() || (request.auth != null && (request.auth.uid in resource.data.assignedVerifierIds || request.auth.uid == resource.data.requestedBy.id));
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid in resource.data.assignedVerifierIds || isAdmin());
      allow delete: if isAdmin() || (request.auth != null && request.auth.uid in resource.data.assignedVerifierIds);
    }

    // Page Hits Analytics
    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true; // Increments happen from background calls
    }
  }
}
