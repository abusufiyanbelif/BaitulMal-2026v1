rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is the user a logged-in administrator?
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Helper: Does the user have specific permission for a module?
    function hasPermission(module, action) {
      let permissions = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions;
      return isAdmin() || (request.auth != null && permissions[module][action] == true);
    }

    // Helper: Is the campaign/lead published for the public?
    function isPublished(resourceData) {
      return resourceData.publicVisibility == 'Published';
    }

    // --- Core Collections ---

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /user_lookups/{lookupId} {
      allow read: if true; // Publicly readable for login mapping
      allow write: if isAdmin();
    }

    match /donors/{donorId} {
      allow read: if request.auth != null && hasPermission('donors', 'read');
      allow write: if isAdmin() || hasPermission('donors', 'create') || hasPermission('donors', 'update');
    }

    match /donations/{donationId} {
      // Public can only read verified donations for impact calculations
      allow read: if (resource != null && resource.data.status == 'Verified') || (request.auth != null && hasPermission('donations', 'read'));
      allow write: if request.auth != null && (hasPermission('donations', 'create') || hasPermission('donations', 'update'));
    }

    match /beneficiaries/{beneficiaryId} {
      allow read: if request.auth != null && hasPermission('beneficiaries', 'read');
      allow write: if request.auth != null && (hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update'));
    }

    match /campaigns/{campaignId} {
      allow read: if isPublished(resource.data) || (request.auth != null && hasPermission('campaigns', 'read'));
      allow write: if request.auth != null && (hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update'));

      match /beneficiaries/{benId} {
        // Public can see counts and non-sensitive link details for published campaigns
        allow read: if isPublished(get(/databases/$(database)/documents/campaigns/$(campaignId)).data) || (request.auth != null && hasPermission('campaigns', 'read'));
        allow write: if request.auth != null && hasPermission('campaigns', 'update');
      }
    }

    match /leads/{leadId} {
      allow read: if isPublished(resource.data) || (request.auth != null && hasPermission('leads-members', 'read'));
      allow write: if request.auth != null && (hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update'));

      match /beneficiaries/{benId} {
        allow read: if isPublished(get(/databases/$(database)/documents/leads/$(leadId)).data) || (request.auth != null && hasPermission('leads-members', 'read'));
        allow write: if request.auth != null && hasPermission('leads-members', 'update');
      }
    }

    match /settings/{settingId} {
      allow read: if true; // Public branding, payment, and info settings
      allow write: if isAdmin();
    }

    match /page_hits/{pageId} {
      allow read: if true;
      allow write: if true; // Analytical increments
    }
  }
}