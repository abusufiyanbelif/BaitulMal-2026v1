rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isActive() {
      return isSignedIn() && getUserData().status == 'Active';
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }
    
    function hasPermission(module, action) {
      let data = getUserData();
      return isAdmin() || (data.permissions != null && 
             data.permissions[module] != null && 
             data.permissions[module][action] == true);
    }

    // --- COLLECTION RULES ---

    // User Profiles
    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId || hasPermission('users', 'read');
      allow create: if isAdmin() || hasPermission('users', 'create');
      allow update: if isAdmin() || request.auth.uid == userId || hasPermission('users', 'update');
      allow delete: if isAdmin() || hasPermission('users', 'delete');
    }

    // User Lookups (Publicly readable for login discovery)
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns
    match /campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
      allow write: if isAdmin() || hasPermission('campaigns', 'create') || hasPermission('campaigns', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if hasPermission('campaigns', 'read');
        allow write: if isAdmin() || hasPermission('campaigns', 'update');
      }
    }

    // Leads
    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
      allow write: if isAdmin() || hasPermission('leads-members', 'create') || hasPermission('leads-members', 'update');
      
      match /beneficiaries/{benId} {
        allow read: if hasPermission('leads-members', 'read');
        allow write: if isAdmin() || hasPermission('leads-members', 'update');
      }
    }

    // Master Beneficiary Registry
    match /beneficiaries/{benId} {
      allow read: if hasPermission('beneficiaries', 'read') || request.auth.uid == benId;
      allow write: if isAdmin() || hasPermission('beneficiaries', 'create') || hasPermission('beneficiaries', 'update');
    }

    // Donations
    match /donations/{donId} {
      allow read: if hasPermission('donations', 'read') || (isSignedIn() && request.auth.uid == resource.data.donorId);
      allow create: if true; // Allow public submissions
      allow update: if isAdmin() || hasPermission('donations', 'update');
      allow delete: if isAdmin() || hasPermission('donations', 'delete');
    }

    // Donors
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read') || request.auth.uid == donorId;
      allow write: if isAdmin() || hasPermission('donors', 'create') || hasPermission('donors', 'update');
    }

    // Verification Pipeline
    match /pending_verifications/{reqId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow create: if isSignedIn() && isActive();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedVerifierIds);
      allow delete: if isAdmin();
    }

    // System Settings & Info
    match /settings/{settingId} {
      allow read: if true; // Publicly readable for branding/UI
      allow write: if isAdmin() || hasPermission('settings', 'update');
    }

    // Page Hits / Analytics
    match /page_hits/{pageId} {
      allow read: if hasPermission('analytics', 'read');
      allow write: if true; // Allow public incrementing
    }
  }
}