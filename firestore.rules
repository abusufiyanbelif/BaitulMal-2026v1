rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    function hasPermission(module, action) {
      return isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[module][action] == true);
    }

    // Public Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Campaigns - Publicly readable if Published
    match /campaigns/{campaignId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
      allow write: if hasPermission('campaigns', 'write') || isAdmin();
      
      match /beneficiaries/{beneficiaryId} {
        allow read: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.publicVisibility == 'Published' || hasPermission('campaigns', 'read');
        allow write: if hasPermission('campaigns', 'write') || isAdmin();
      }
    }

    // Leads - Publicly readable if Published
    match /leads/{leadId} {
      allow read: if resource.data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
      allow write: if hasPermission('leads-members', 'write') || isAdmin();

      match /beneficiaries/{beneficiaryId} {
        allow read: if get(/databases/$(database)/documents/leads/$(leadId)).data.publicVisibility == 'Published' || hasPermission('leads-members', 'read');
        allow write: if hasPermission('leads-members', 'write') || isAdmin();
      }
    }

    // Donations - Verified donations are publicly listable for progress calculation
    match /donations/{donationId} {
      allow read: if resource.data.status == 'Verified' || hasPermission('donations', 'read');
      allow list: if (request.query.limit <= 100 && (resource == null || resource.data.status == 'Verified')) || hasPermission('donations', 'read');
      allow write: if hasPermission('donations', 'write') || isAdmin();
    }
    
    // Master Beneficiaries & Donors - Strictly Private
    match /beneficiaries/{beneficiaryId} {
      allow read: if hasPermission('beneficiaries', 'read');
      allow write: if hasPermission('beneficiaries', 'write') || isAdmin();
    }
    match /donors/{donorId} {
      allow read: if hasPermission('donors', 'read');
      allow write: if hasPermission('donors', 'write') || isAdmin();
    }

    // Users & Lookups
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }
    match /user_lookups/{lookupId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /page_hits/{pageId} {
      allow read, write: if true;
    }
  }
}